---
---

<section class="py-24 bg-linear-to-b from-white to-gray-50 px-6">
  <div class="max-w-3xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
    <div class="grid md:grid-cols-5">
      <!-- 側邊欄資訊 -->
      <div class="md:col-span-2 bg-blue-600 p-8 text-white flex flex-col justify-between">
        <div>
          <h2 class="text-3xl font-bold mb-4">聯絡我們</h2>
          <p class="text-blue-100 leading-relaxed">
            對 eSIM 或旅遊行程有任何疑問嗎？填寫右側表單，我們的旅遊專家會盡快與您聯繫。
          </p>
        </div>
        
        <div class="space-y-4 mt-12">
          <div class="flex items-center gap-3">
            <div class="bg-blue-500/30 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <span>support@example.com</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="bg-blue-500/30 p-2 rounded-lg">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <span>台北市中山區南京東路</span>
          </div>
        </div>
      </div>

      <!-- 表單本體 -->
      <form class="md:col-span-3 p-8 md:p-12 space-y-6">
        <div>
          <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">姓名</label>
          <input 
            type="text" 
            id="name" 
            name="name" 
            placeholder="如何稱呼您？"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none"
            required
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">電子郵件</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="example@mail.com"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none"
            required
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">訊息內容</label>
          <textarea 
            id="message" 
            name="message" 
            rows="4" 
            placeholder="請輸入您的問題..."
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none resize-none"
            required
          ></textarea>
        </div>

        <button 
          type="submit" 
          class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-200 transition-all transform hover:-translate-y-0.5 active:scale-95"
        >
          傳送訊息
        </button>
      </form>
    </div>
  </div>
</section>
