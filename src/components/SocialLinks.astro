---
interface Props {
  variant?: 'default' | 'inverse';
  align?: 'left' | 'center';
  heading?: string;
  subheading?: string;
}

const {
  variant = 'default',
  align = 'center',
  heading = '追蹤我｜Follow Me',
  subheading = '在 IG、FB、YouTube 上看更多旅遊筆記與省錢情報',
} = Astro.props;
---

<aside class:list={['social-links', `is-${variant}`, `align-${align}`]} aria-label="社群連結">
  {heading && <div class="social-heading">{heading}</div>}
  {subheading && <p class="social-sub">{subheading}</p>}
  <div class="social-row">
    <a
      class="social-btn ig"
      href="https://www.instagram.com/comebacktraveler?igsh=dXZneDhuOXc1Zmlv"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram @comebacktraveler"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M12 2.163c3.204 0 3.584.012 4.849.07 3.252.149 4.771 1.691 4.919 4.919.058 1.265.07 1.645.07 4.849 0 3.205-.012 3.584-.07 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.645.07-4.849.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.163 6.163 0 100 12.326 6.163 6.163 0 000-12.326zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
      </svg>
      <span>Instagram</span>
    </a>

    <a
      class="social-btn fb"
      href="https://www.facebook.com/share/1VwwukZjyr/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Facebook 粉絲頁"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
      <span>FB 粉絲頁</span>
    </a>

    <a
      class="social-btn fb"
      href="https://www.facebook.com/share/1BxEbRhBcW/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Facebook"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
      <span>Facebook</span>
    </a>

    <a
      class="social-btn yt"
      href="http://www.youtube.com/@AndyFeverDream"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="YouTube @AndyFeverDream"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
      </svg>
      <span>YouTube</span>
    </a>
  </div>
</aside>

<style>
  .social-links {
    --sl-ink: #1a1208;
    --sl-ink-light: #4a3f2f;
    --sl-paper: #faf8f3;
    --sl-paper-warm: #f2ede0;
    --sl-border: #d4c9b0;
    --sl-accent: #c0392b;
    margin: 40px 0;
    padding: 24px 24px 22px;
    border: 1.5px solid var(--sl-border);
    border-radius: 8px;
    background: var(--sl-paper-warm);
    font-family: 'Noto Sans TC', sans-serif;
  }
  .social-links.align-center { text-align: center; }
  .social-links.align-left { text-align: left; }

  .social-heading {
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: 17px;
    color: var(--sl-ink);
    letter-spacing: 0.02em;
    margin-bottom: 6px;
  }
  .social-sub {
    font-size: 13.5px;
    color: var(--sl-ink-light);
    line-height: 1.65;
    margin: 0 0 16px;
  }

  .social-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: inherit;
  }
  .social-links.align-center .social-row { justify-content: center; }
  .social-links.align-left .social-row { justify-content: flex-start; }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px;
    border-radius: 999px;
    border: 1.5px solid var(--sl-ink);
    background: var(--sl-paper);
    color: var(--sl-ink);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    line-height: 1;
    transition: background 0.15s, color 0.15s, border-color 0.15s, transform 0.1s;
  }
  .social-btn svg { display: block; flex-shrink: 0; }
  .social-btn:hover { transform: translateY(-1px); }

  .social-btn.ig:hover {
    background: linear-gradient(45deg, #f09433, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888);
    color: #fff;
    border-color: transparent;
  }
  .social-btn.fb:hover { background: #1877f2; color: #fff; border-color: #1877f2; }
  .social-btn.yt:hover { background: #ff0000; color: #fff; border-color: #ff0000; }

  /* Inverse variant — for dark backgrounds (e.g. subscribe-box) */
  .social-links.is-inverse {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.15);
  }
  .social-links.is-inverse .social-heading { color: #faf8f3; }
  .social-links.is-inverse .social-sub { color: #d4c9b0; }
  .social-links.is-inverse .social-btn {
    background: transparent;
    color: #faf8f3;
    border-color: rgba(250, 248, 243, 0.4);
  }
  .social-links.is-inverse .social-btn:hover { border-color: transparent; }

  @media (max-width: 600px) {
    .social-links { padding: 20px 16px; }
    .social-row { gap: 8px; }
    .social-btn { padding: 8px 12px; font-size: 12.5px; }
    .social-btn span { display: inline; }
  }
</style>
