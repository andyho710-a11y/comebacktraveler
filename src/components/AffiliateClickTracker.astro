<script is:inline>
  (function () {
    if (window.__cbtAffiliateClickTracker) return;
    window.__cbtAffiliateClickTracker = true;

    var affiliateSelector = [
      'a[rel~="sponsored"]',
      'a[href*="coupa.ng"]',
      'a[href*="collshp.com"]',
      'a[href*="afflink.one"]',
      'a[href*="onelink.one"]',
      'a[data-affiliate]'
    ].join(',');

    function getAffiliateDomain(href) {
      try {
        return new URL(href, window.location.href).hostname;
      } catch (error) {
        return '';
      }
    }

    function getAffiliateNetwork(link, href) {
      var explicit = link.getAttribute('data-affiliate');
      if (explicit) return explicit;

      var hostname = getAffiliateDomain(href);
      if (!hostname) return 'unknown';

      if (hostname.indexOf('coupa.ng') !== -1) return 'coupang';
      if (hostname.indexOf('collshp.com') !== -1) return 'shopee';
      if (hostname.indexOf('afflink.one') !== -1) return 'affiliates_one';
      if (hostname.indexOf('onelink.one') !== -1) return 'affiliates_one';
      return 'affiliate';
    }

    function getButtonText(link) {
      var label = link.getAttribute('aria-label') || link.textContent || '';
      return label.replace(/\s+/g, ' ').trim().slice(0, 120);
    }

    function getTrackingValue(link, attribute) {
      return (link.getAttribute(attribute) || '').trim().slice(0, 120);
    }

    function getCtaPosition(link) {
      var explicit = getTrackingValue(link, 'data-cta-position');
      if (explicit) return explicit;

      if (link.closest('.product-card')) return 'product_card';
      if (link.closest('.shopee-block')) return 'primary_list';
      if (link.classList.contains('inline')) return 'inline';

      var documentHeight = document.documentElement.scrollHeight || 1;
      var ratio = (window.scrollY + link.getBoundingClientRect().top) / documentHeight;
      if (ratio < 0.33) return 'article_top';
      if (ratio > 0.66) return 'article_bottom';
      return 'article_body';
    }

    document.addEventListener('click', function (event) {
      var target = event.target;
      if (!target || !target.closest) return;

      var link = target.closest(affiliateSelector);
      if (!link || !link.href || typeof window.gtag !== 'function') return;

      window.gtag('event', 'affiliate_click', {
        page_path: window.location.pathname,
        page_title: document.title,
        button_text: getButtonText(link),
        product_name: getTrackingValue(link, 'data-affiliate-product') || getButtonText(link),
        product_category: getTrackingValue(link, 'data-affiliate-category') || 'uncategorized',
        cta_position: getCtaPosition(link),
        link_url: link.href,
        link_domain: getAffiliateDomain(link.href),
        category: 'affiliate',
        affiliate_network: getAffiliateNetwork(link, link.href),
        transport_type: 'beacon'
      });
    }, true);
  })();
</script>
