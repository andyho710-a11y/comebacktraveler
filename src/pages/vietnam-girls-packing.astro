const title = "越南女生旅行用品清單｜防曬、防蚊、個人用品怎麼準備";
const description = "越南女生旅行要帶什麼？住越南十年的在地人整理防曬、防蚊、個人清潔、安全防盜、美妝保養，哪些台灣先帶、哪些當地再買，一篇說清楚。";
const canonical = "https://comebacktraveler.com/vietnam-girls-packing";
const cover = "https://comebacktraveler.com/vietnam-airport-queue.jpg";

const shopeeUrl = "https://collshp.com/andyho8431/category/3834915?share_channel_code=6&view=storefront";

const products = [
