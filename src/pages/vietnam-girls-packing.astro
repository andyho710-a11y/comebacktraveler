import SocialLinks from '../components/SocialLinks.astro';

const title = "越南女生旅行必帶物品｜住越南十年，這幾樣沒帶你會後悔";
const description = "越南女生旅行要帶什麼？住越南十年的在地人整理：防曬、防蚊、私密處護理、安全防身、美妝保養，哪些台灣帶、哪些當地買，一篇說清楚。含蝦皮選品清單，酷澎僅作補充比價。";
const canonical = "https://comebacktraveler.com/vietnam-girls-packing";
const cover = "https://comebacktraveler.com/vietnam-airport-queue.jpg";

const shopeeUrl = "https://collshp.com/andyho8431/category/3834915?share_channel_code=6&view=storefront";

const faqs = [
  {
    q: "越南女生旅行一個人安全嗎？",
    a: "主要觀光城市（胡志明、河內、峴港、會安）整體安全，單獨女生旅行沒問題，但要注意包包別背後側、避免深夜獨行偏僻巷弄、機車招手攬客要謹慎。有防盜包 + 注意動線，放心去。",
  },
  {
    q: "越南當地買得到台灣的保養品嗎？",
    a: "知名國際品牌（Biore、資生堂等）在大城市百貨有，但台灣熟悉的小品牌、藥妝通路不一定找得到，而且價格比台灣貴。日常慣用的防曬、保養建議從台灣帶足。",
  },
  {
    q: "越南需要準備多少現金？",
    a: "胡志明市、河內大部分餐廳、商場可刷卡，但夜市、路邊攤、機車計程車（Xe Om）只收現金。建議備 200-300 萬越南盾現金（約台幣 2,600-4,000 元）作為日常零用，大額消費用信用卡。",
  },
];
