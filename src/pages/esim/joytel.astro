<script>
  var form = /** @type {HTMLFormElement|null} */ (document.getElementById('comment-form'));
  var successMsg = document.getElementById('form-success');
  if (form && successMsg) {
    var f = form, s = successMsg;
    f.addEventListener('submit', async function(e) {
      e.preventDefault();
      var data = new FormData(f);
      await fetch('/', { method: 'POST', body: data });
      f.hidden = true;
      s.hidden = false;
