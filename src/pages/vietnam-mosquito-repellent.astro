  { rank: "3", item: "防蚊貼 / 防蚊手環", scene: "小孩輔助、短時間室內外移動", buy: "蝦皮" },
  { rank: "4", item: "薄長袖 / 防蚊衣", scene: "水樂園、郊區、戶外餐廳", buy: "蝦皮" },
