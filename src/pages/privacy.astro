      color: var(--ink);
      font-family: var(--sans);
      line-height: 1.85;
    }
    .site-header {
      border-bottom: 1px solid var(--border);
      padding: 18px 24px;
      text-align: center;
    }
    .site-name {
      font-family: var(--serif);
      font-weight: 900;
      font-size: 22px;
      color: var(--ink);
      text-decoration: none;
    }
    .site-name span { color: var(--accent); }
    main {
      max-width: 760px;
      margin: 0 auto;
      padding: 56px 24px 24px;
    }
    h1 {
      font-family: var(--serif);
      font-size: 34px;
      font-weight: 900;
      margin: 0 0 8px;
      letter-spacing: 0.5px;
    }
    .updated {
      color: var(--ink-light);
      font-size: 14px;
      margin: 0 0 36px;
    }
    h2 {
      font-family: var(--serif);
      font-size: 22px;
      font-weight: 700;
      margin: 40px 0 14px;
      padding-left: 14px;
      border-left: 4px solid var(--accent);
      line-height: 1.4;
    }
    p, li { font-size: 16px; color: #2a2a2a; }
    ul { padding-left: 22px; margin: 8px 0 16px; }
    li { margin-bottom: 6px; }
    a { color: var(--accent); }
    a:hover { text-decoration: underline; }
    strong { color: var(--ink); }

    footer {
      border-top: 2px solid var(--ink);
      padding: 40px 24px;
      text-align: center;
      font-size: 13px;
      color: var(--ink-light);
      margin-top: 60px;
    }
    .footer-nav {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 6px 20px;
      margin-top: 14px;
    }
    .footer-nav a {
      color: var(--accent);
      text-decoration: none;
