---
import BlogLayout from '../layouts/BlogLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import SiteNav from '../components/SiteNav.astro';
import { prepArticles, travelArticles, esimArticles, lifeArticles } from '../data/articles.js';

const articleByHref = new Map(
  [...prepArticles, ...travelArticles, ...esimArticles, ...lifeArticles].map((a) => [a.href, a])
);
const pickArticles = (hrefs) => hrefs.map((href) => articleByHref.get(href)).filter(Boolean);

const vietnamPrepArticles = pickArticles([
  '/vietnam-travel-essentials',
  '/vietnam-packing-list',
  '/vietnam-mosquito-repellent-guide',
  '/vietnam-guide',
  '/vietnam-taxi-app-guide',
  '/esim/saigon-airport-sim',
]);
const packingListArticles = pickArticles([
  '/first-trip-packing-list',
  '/vietnam-girls-packing',
  '/kids-travel-guide',
  '/kids-travel-amazing-bay',
  '/saigon-couple-walk',
  '/vietnam-jcb-lounge',
]);
const internetArticles = pickArticles([
  '/esim/overseas-internet-guide',
  '/esim/saigon-airport-sim',
  '/esim',
  '/esim/install',
  '/esim/troubleshoot',
]);
const otherPrepArticles = pickArticles([
  '/japan-guide',
  '/korea-guide',
  '/esim/japan',
  '/esim/korea',
  '/esim/china',
  '/esim/china-routing-2026',
  '/thsr-guide',
]);
const restartNoteArticles = pickArticles(['/story', ...lifeArticles.map((a) => a.href)]);
---

<BlogLayout
  title="重來的旅人｜越南旅遊準備與出國用品清單"
  description="重來的旅人整理越南旅遊準備、出國用品、防蚊、防盜、轉接頭、打包清單與省錢避坑資訊，寫給第一次去越南或久久才出國一次的台灣旅人。"
  keywords="越南旅遊準備, 出國用品清單, 越南行李清單, 越南必備小物, 越南防蚊, 防盜包, 轉接頭, 越南自由行"
  ogImage="/esim-cover.jpg"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet" />

  <div class="root">

    <!-- Header -->
    <SiteNav />

    <!-- Hero -->
    <div class="hero">
      <div class="category-tag">越南旅遊準備 · 出國用品清單</div>
      <h1>第一次去越南，<br>出發前先把東西備齊</h1>
      <p class="subtitle">
        我在越南住了十年，最常被朋友問的不是景點，而是「到底要帶什麼」。<br>
        這裡把越南防蚊、防曬、防盜、轉接頭、打包清單與落地避坑整理成出發前能直接照看的清單。
      </p>
      <div class="meta">
        <div class="author-dot">旅</div>
        <div>
          <div class="meta-author">重來的旅人</div>
          <div>越南生活 10 年 · 出國用品整理 · 省錢避坑</div>
        </div>
      </div>
    </div>

    <!-- Author note -->
    <div class="article">
      <div class="story-box">
        <strong>這不是觀光景點大全，而是出發前準備站。</strong><br><br>
        如果你久久才出國一次，最怕的通常不是少玩一個景點，而是落地才發現沒網路、沒防蚊、充電器不能用、
        包包背錯邊、行李塞了一堆用不到的東西。我把越南生活十年的經驗，拆成一份份可以直接檢查的清單。
        <br><br>
        <a href="/vietnam-travel-essentials" style="color:var(--accent);font-weight:600;font-size:15px;">→ 先看越南出國用品清單</a>
        <span class="story-link-sep">／</span>
        <a href="/about" style="color:var(--accent);font-weight:600;font-size:15px;">認識作者</a>
      </div>

    </div><!-- /article (story box) -->

    <!-- Intro content: 提升首頁原創內容與 E-E-A-T -->
    <div class="article intro-content">
      <h2>這個網站幫誰準備？</h2>
      <p>
        這個網站主軸很單純：<strong>越南旅遊準備與出國用品清單。</strong>
        寫給第一次去越南、或久久才出國一次的台灣旅人。你不需要先懂一堆品牌和票券，
        只要知道哪些東西該從台灣帶、哪些可以到當地買、哪些錢不要在機場臨時花。
      </p>
      <p>
        我在越南住了十年，自己訂票、自己找路，也被機場和路邊計程車坑過。現在我把那些經驗寫成可操作的準備筆記：
        防蚊、防曬、防盜、220V 電壓、行李打包、女生旅行用品、機場上網和叫車順序。
      </p>
      <p>內容分成幾塊，你可以從上方選單或下面的卡片進去：</p>
      <ul class="intro-list">
        <li>
          <strong>越南出國用品</strong>：防曬、防蚊、充電器、防盜包、收納袋與常備藥，先用清單把行李備齊。
        </li>
        <li>
          <strong>打包與女生旅行</strong>：行李箱大小、手提與託運怎麼分、女生防曬防蚊與個人用品怎麼準備。
        </li>
        <li>
          <strong>越南落地避坑</strong>：機場通關、上網、叫車、貴賓室與親子行程，優先寫真正在越南會遇到的問題。
        </li>
        <li>
          <strong>出國上網整理</strong>：eSIM、WiFi 機、漫遊與越南機場 SIM 卡怎麼選，依官方規格與使用情境整理。
        </li>
      </ul>
      <p class="intro-note">
        說明一下：本站部分連結是聯盟行銷連結，你透過它們購買，我會拿到一點分潤，但<strong>不會影響你的價格</strong>。
        部分內容來自親身經驗，部分是依公開資訊、官方頁面與使用情境整理，我會盡量標示清楚，不把資料整理寫成個人使用心得。更完整的揭露寫在
        <a href="/privacy">隱私權政策</a>，想多認識我可以看
        <a href="/about">關於我</a>。
      </p>
      <nav class="category-nav" aria-label="首頁分類">
        <a href="#vietnam-prep">越南旅遊準備</a>
        <a href="#packing-list">出國用品清單</a>
        <a href="#internet-prep">出國上網整理</a>
        <a href="#other-prep">其他出國準備</a>
        <a href="#restart-notes">重來筆記</a>
      </nav>
    </div>

    <!-- 越南旅遊準備（首頁第一主軸）-->
    <div id="vietnam-prep" class="home-section">
      <h2>越南旅遊準備</h2>
      <p class="section-desc">第一次去越南先看這裡。防蚊、防盜、叫車、機場上網與落地避坑，先把最容易出錯的地方排好。</p>
      <div class="home-grid">
        {vietnamPrepArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- 出國用品清單（首頁第二主軸）-->
    <div id="packing-list" class="home-section">
      <h2>出國用品清單</h2>
      <p class="section-desc">行李箱、手提行李、女生旅行用品、親子出遊與貴賓室準備，整理成出發前可以逐項檢查的清單。</p>
      <div class="home-grid">
        {packingListArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- 出國上網 eSIM（後段，屬出國準備的一項，非主角）-->
    <div id="internet-prep" class="home-section">
      <h2>出國上網整理</h2>
      <p class="section-desc">上網只是出國準備的一項。這裡優先放通用上網選擇、越南機場 SIM、eSIM 安裝與問題排解。</p>
      <a href="/esim-quiz" class="quiz-cta">🧭 30 秒測出你該用哪種上網方案 →</a>
      <div class="home-grid">
        {internetArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- 其他出國準備參考 -->
    <div id="other-prep" class="home-section">
      <h2>其他出國準備</h2>
      <p class="section-desc">日本、韓國、中國大陸與高鐵省錢文章保留在這裡，作為越南以外的出國準備參考。</p>
      <div class="home-grid">
        {otherPrepArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- 重來筆記（低權重作者內容）-->
    <div id="restart-notes" class="home-section restart-section">
      <h2>重來筆記</h2>
      <p class="section-desc">這裡只保留一小段作者與重新出發的背景。想知道我為什麼寫這個站，可以從關於我或重來筆記慢慢看。</p>
      <div class="restart-links">
        <a href="/about">關於我</a>
        {restartNoteArticles.map((a) => (
          <a href={a.href}>{a.title}</a>
        ))}
      </div>
    </div>

    <div class="article"><!-- resume narrow -->
      <!-- Social Links -->
      <SocialLinks
        heading="追蹤我｜Follow Me"
        subheading="IG、FB、YouTube 上會分享更多越南旅遊準備、出國用品與避坑筆記"
      />
    </div>

    <!-- Footer -->
    <footer class="site-footer">
      <strong>重來的旅人</strong> · 越南旅遊準備與出國用品清單<br>
      <div class="footer-nav">
        <a href="/esim">eSIM 比較</a>
        <a href="/esim/japan">日本 eSIM</a>
        <a href="/esim/korea">韓國 eSIM</a>
        <a href="/esim/china">中國 eSIM</a>
        <a href="/esim/china-routing-2026">eSIM 封包送中爭議</a>
        <a href="/japan-guide">日本攻略</a>
        <a href="/korea-guide">韓國攻略</a>
        <a href="/vietnam-guide">越南攻略</a>
        <a href="/esim/saigon-airport-sim">胡志明機場 SIM</a>
        <a href="/vietnam-jcb-lounge">越南貴賓室</a>
        <a href="/kids-travel-guide">親子旅遊</a>
        <a href="/thsr-guide">高鐵省錢</a>
        <a href="/about">關於</a>
        <a href="/story">作者故事</a>
        <a href="/contact">聯絡我</a>
        <a href="/life-restart-naval">人生筆記</a>
        <a href="/privacy">隱私權政策</a>
      </div>
      <span style="display:block;margin-top:10px;">越南生活 10 年 · 出國用品整理 · 省錢避坑</span>
    </footer>

  </div>
</BlogLayout>

<script>
  var form = document.getElementById('subscribe-form');
  var success = document.getElementById('subscribe-success');
  if (form && success) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var data = new FormData(form as HTMLFormElement);
      await fetch('/', { method: 'POST', body: data });
      (form as HTMLElement).hidden = true;
      (success as HTMLElement).hidden = false;
    });
  }
</script>

<style>
  .root {
    --ink: #1a1208;
    --ink-light: #4a3f2f;
    --paper: #faf8f3;
    --paper-warm: #f2ede0;
    --accent: #c0392b;
    --gold: #b8860b;
    --border: #d4c9b0;
    --serif: 'Noto Serif TC', serif;
    --sans: 'Noto Sans TC', sans-serif;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.8;
    font-size: 17px;
    min-height: 100vh;
  }

  /* Header */
  .site-header {
    border-bottom: 2px solid var(--ink);
    padding: 18px 0;
    text-align: center;
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .site-name {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-decoration: none;
  }
  .site-name span { color: var(--accent); }

  /* Hero */
  .hero {
    max-width: 740px;
    margin: 60px auto 0;
    padding: 0 24px;
  }
  .category-tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    border-left: 3px solid var(--accent);
    padding-left: 10px;
    margin-bottom: 20px;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 900;
    font-size: clamp(28px, 5vw, 44px);
    line-height: 1.35;
    margin-bottom: 20px;
  }
  .subtitle {
    font-size: 17px;
    color: var(--ink-light);
    margin-bottom: 32px;
    line-height: 1.75;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
    font-size: 13px;
    color: var(--ink-light);
  }
  .author-dot {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--serif);
    font-weight: 900;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .meta-author { font-weight: 500; font-size: 14px; color: var(--ink); }

  /* Article body */
  .article {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }
  .article p { margin-bottom: 1.4em; }

  h2 {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 26px;
    margin: 52px 0 16px;
    position: relative;
    padding-left: 16px;
  }
  h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 80%;
    background: var(--accent);
    border-radius: 2px;
  }

  /* Story box */
  .story-box {
    background: var(--paper-warm);
    border-left: 4px solid var(--accent);
    padding: 24px 28px;
    margin: 0 0 40px;
    border-radius: 0 6px 6px 0;
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink-light);
    line-height: 1.9;
  }
  .story-box strong { color: var(--ink); font-weight: 600; }
  .story-link-sep { color: var(--border); margin: 0 8px; }

  /* Intro content block */
  .intro-content { padding-bottom: 0; }
  .intro-content h2 { margin-top: 8px; }
  .intro-content p { font-size: 16px; color: var(--ink-light); }
  .intro-content strong { color: var(--ink); font-weight: 600; }
  .intro-list { margin: 0 0 1.4em; padding-left: 0; list-style: none; }
  .intro-list li {
    font-size: 15.5px;
    color: var(--ink-light);
    line-height: 1.8;
    padding: 14px 0 14px 18px;
    border-left: 3px solid var(--border);
    margin-bottom: 12px;
  }
  .intro-list li strong { color: var(--ink); }
  .intro-note {
    font-size: 14px;
    color: var(--ink-light);
    background: var(--paper-warm);
    border-radius: 6px;
    padding: 16px 20px;
  }
  .intro-note a { color: var(--accent); }
  .category-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 22px 0 0;
  }
  .category-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 6px 12px;
    border: 1.5px solid var(--border);
    border-radius: 999px;
    color: var(--ink);
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    background: #fffdf9;
  }
  .category-nav a:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* Life notes section */
  .life-section { padding-top: 0; padding-bottom: 24px; }
  .life-section h2 { margin-top: 8px; }
  .life-grid { grid-template-columns: 1fr; max-width: 620px; }

  /* Wide two-column layout */
  .wide-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 56px;
    align-items: start;
  }
  .section-col { padding-bottom: 48px; }
  .section-col h2 { margin-top: 52px; }
  .section-desc { margin-bottom: 0; }

  .quiz-cta {
    display: inline-block;
    margin: 16px 0 0;
    padding: 12px 18px;
    border: 1.5px solid var(--accent);
    border-radius: 8px;
    background: #fef9f5;
    color: var(--accent);
    font-weight: 600;
    font-size: 14.5px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .quiz-cta:hover { background: #fbeee6; }

  /* Home full-width sections (出國前準備 / 旅遊 / eSIM / 人生筆記) */
  .home-section { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .home-section > h2 { margin-top: 52px; }
  .home-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
    margin: 20px 0 8px;
  }
  .home-grid.life-grid { grid-template-columns: 1fr; max-width: 640px; }
  .restart-section {
    max-width: 740px;
    padding-bottom: 48px;
  }
  .restart-links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 16px;
  }
  .restart-links a {
    color: var(--accent);
    font-size: 14.5px;
    font-weight: 600;
    text-decoration: none;
  }
  .restart-links a:hover { text-decoration: underline; }

  /* Single tool card (省錢工具導引，取代首頁折扣明細) */
  .tool-card {
    display: block;
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 22px 24px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, box-shadow 0.15s;
    margin-top: 8px;
  }
  .tool-card:hover { border-color: var(--accent); box-shadow: 0 4px 16px rgba(192,57,43,0.08); }
  .tool-card-title { font-family: var(--serif); font-weight: 900; font-size: 18px; margin-bottom: 8px; color: var(--ink); }
  .tool-card-desc { font-size: 14px; color: var(--ink-light); line-height: 1.7; margin-bottom: 12px; }
  .tool-card-link { font-size: 14px; font-weight: 500; color: var(--accent); }

  /* Article cards */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin: 20px 0 0;
  }
  .article-card {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 22px 20px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .article-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 16px rgba(192,57,43,0.08);
  }
  .article-card-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .article-card-title {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 16px;
    line-height: 1.45;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .article-card-desc {
    font-size: 13.5px;
    color: var(--ink-light);
