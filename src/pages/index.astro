---
import BlogLayout from '../layouts/BlogLayout.astro';
import ContactForm from '../components/ContactForm.astro';

const AFFILIATE_LINK = 'https://onelink.one/s/PclP0';

const offers = [
  { bank: '國泰世華 CUBE 信用卡', title: '星野集團日本飯店 85 折', badge: '15% OFF', code: 'CUBEHO2685' },
  { bank: '國泰世華 CUBE 信用卡', title: '日本旅遊商品 88 折', badge: '12% OFF', code: 'CUBEJP268804' },
  { bank: '玉山銀行公務人員國旅卡', title: '全站滿 $3,000 享 94 折', badge: '6% OFF', code: 'ESUNDC26Q294' },
  { bank: '新光銀行 Visa 卡', title: '海外商品 93 折', badge: '7% OFF', code: 'VSKB269304' },
  { bank: '中國信託 LINE Pay Visa', title: '台港澳飯店 12% 回饋', badge: '12% 回饋', code: 'CTBCLP26CH1' },
  { bank: '中華郵政 VISA 金融卡', title: '高鐵國旅聯票滿 $1,000 折 $100', badge: '$100 OFF', code: 'POSTHS268504' },
];

const esimArticles = [
  {
    tag: 'eSIM 完整攻略',
    title: '出國 eSIM 怎麼選？六家品牌完整比較',
    desc: '把 JOYTEL、DJB、Klook、Airalo 等六家整理成一張表。5 分鐘做決定，不用再 Google 到天亮。',
    href: '/esim',
    label: '看比較表 →',
  },
  {
    tag: '日本 eSIM 2026',
    title: '日本 eSIM 推薦 2026｜只推這兩張',
    desc: '原生線路 vs 漫遊線路差在哪？哪家有中文客服？踩過坑的過來人，幫你把選擇縮到最小。',
    href: '/esim/japan',
    label: '看日本推薦 →',
  },
  {
    tag: '韓國 eSIM 2026',
    title: '韓國 eSIM 推薦 2026｜只推這兩張',
    desc: 'SKT 原生線路、Naver Map 導航都能跑，搭配中文 LINE 客服，首爾到濟州都不怕斷線。',
    href: '/esim/korea',
    label: '看韓國推薦 →',
  },
  {
    tag: 'eSIM 安裝教學',
    title: 'eSIM 怎麼安裝？iPhone + Android 圖解',
    desc: '收到 QR Code 之後卡關了？iPhone、三星 Galaxy、Google Pixel 的設定路徑全圖解，5 分鐘搞定。',
    href: '/esim/install',
    label: '看安裝步驟 →',
  },
  {
    tag: 'JOYTEL 深度評測',
    title: 'JOYTEL eSIM 評測 2026｜速度實測、客服體驗',
    desc: '用了三次才來寫這篇。日本韓國實測速度數據、LINE 客服回應時間、與 DJB 和 WaySim 的完整比較表。',
    href: '/esim/joytel',
    label: '看 JOYTEL 評測 →',
  },
  {
    tag: 'eSIM 問題排解',
    title: 'eSIM 設定失敗怎麼辦？10 個常見問題解法',
    desc: 'QR Code 掃不到、安裝失敗、有訊號沒網路、APN 設定錯誤——10 個問題逐一解法，一篇全搞定。',
    href: '/esim/troubleshoot',
    label: '看問題解法 →',
  },
  {
    tag: '中國大陸上網',
    title: '去中國大陸用 eSIM｜GFW 封鎖哪些 App？',
    desc: '一般日韓 eSIM 在大陸無效。大陸線路選擇、防火長城封鎖 App 清單、出發前準備清單，全整理好了。',
    href: '/esim/china',
    label: '看大陸上網攻略 →',
  },
];

const travelArticles = [
  {
    tag: '高鐵省錢攻略',
    title: '高鐵怎麼買最便宜？2026 商務通勤族省錢攻略',
    desc: '定期票、早鳥、KKday 晚鳥票完整比較，依你的搭乘頻率找最對的方案，一年省下 8,000 元以上。',
    href: '/thsr-guide',
    label: '看高鐵省錢攻略 →',
  },
  {
    tag: '日本自由行 2026',
    title: '日本自由行行程規劃｜東京、京都、大阪推薦',
    desc: '東京必去景點、京都季節限定活動、大阪美食推薦，搭配 Klook 提前預訂，省錢又省時。',
    href: '/japan-guide',
    label: '看日本行程攻略 →',
  },
  {
    tag: '韓國自由行 2026',
    title: '韓國自由行行程規劃｜首爾、釜山完整攻略',
    desc: '首爾景福宮、弘大購物、釜山海雲台，Klook 行程搶先預訂，現場排隊少一小時。',
    href: '/korea-guide',
    label: '看韓國行程攻略 →',
  },
  {
    tag: '越南旅遊 2026',
    title: '越南旅遊省時攻略：帶小孩出國不崩潰！',
    desc: '海關排隊 40 分鐘、小孩餓到抗議——住過越南十年的過來人，告訴你快速通關和 eSIM 怎麼準備。',
    href: '/vietnam-guide',
    label: '看越南旅遊攻略 →',
  },
  {
    tag: '關於這個人',
    title: '從越南副總到 Uber 司機：重新出發的故事',
    desc: '越南工廠十年、養蝦失敗、跑 Uber、父親離世——那些跌跤的歲月，才是真正的養分。',
    href: '/story',
    label: '看作者的故事 →',
  },
];
---

<BlogLayout
  title="重來的旅人｜2026 出國上網 eSIM 比較、旅遊攻略與省錢指南"
  description="提供 2026 最實用的日本、韓國、越南旅遊攻略。深度比較各大品牌 eSIM（JOYTEL、DJB、Klook），並分享高鐵與國旅省錢秘訣。把踩過的坑，變成你的攻略。"
  keywords="eSIM推薦, 2026出國上網, 日本eSIM推薦, 韓國eSIM比較, Klook優惠碼, 高鐵省錢, 重來的旅人"
  ogImage="/esim-cover.jpg"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet" />

  <div class="root">

    <!-- Header -->
    <header class="site-header">
      <a href="/" class="site-name">重來的<span>旅人</span></a>
    </header>

    <!-- Hero -->
    <div class="hero">
      <div class="category-tag">關於這個網站</div>
      <h1>前半生跌了很多跤<br>現在把坑，整理給你</h1>
      <p class="subtitle">
        我在越南工廠當過副總、養蝦失敗、跑過 Uber、父親走了之後才真正開始重新出發。<br>
        這個網站，是一個 40 幾歲台灣男人寫給自己、也寫給你的筆記。
      </p>
      <div class="meta">
        <div class="author-dot">旅</div>
        <div>
          <div class="meta-author">重來的旅人</div>
          <div>越南生活 10 年 · 自媒體行銷 · 2025 重新出發</div>
        </div>
      </div>
    </div>

    <!-- Author Story -->
    <div class="article">
      <div class="story-box">
        <strong>我不是什麼旅遊達人，也沒有光鮮亮麗的履歷。</strong><br><br>
        我是家裡文具工廠的第二代。國中叛逆、KTV 鬧事住院，被送去加拿大九個月帶回來。
        後來去越南幫父親管廠，擔任副總一待就是十年。
        養蝦失敗、環保藥劑事業失敗，靠父親收拾殘局。
        2018 年回台灣，工廠被拍賣，跑起了 Uber。
        外婆走了，父親肺癌末期也走了。那是人生最深的失落。<br><br>
        2025 年，我遇見了主耶穌，重新找回了方向。
        這個網站，是我把這些年踩過的坑，整理成對你有用的東西。
        <br><br>
        <a href="/story" style="color:var(--accent);font-weight:600;font-size:15px;">→ 看完整的故事</a>
      </div>

    </div><!-- /article (story box) -->

    <!-- Two-column wide section -->
    <div class="wide-wrap">

      <div class="section-col">
        <h2>出國上網攻略</h2>
        <p class="section-desc">出門在外沒有網路，那種慌是真的。以下是我整理的 eSIM 選購指南，不業配，是用過才說。</p>
        <div class="card-grid">
          {esimArticles.map((a) => (
            <a href={a.href} class="article-card">
              <div class="article-card-tag">{a.tag}</div>
              <div class="article-card-title">{a.title}</div>
              <p class="article-card-desc">{a.desc}</p>
              <div class="article-card-link">{a.label}</div>
            </a>
          ))}
        </div>
      </div>

      <div class="section-col">
        <h2>旅行省錢攻略</h2>
        <p class="section-desc">票怎麼買最便宜、行程怎麼搭最划算、哪個 Klook 活動值得提前訂——跑過 Uber 的人，對每一塊錢都特別敏感。</p>
        <div class="card-grid">
          {travelArticles.map((a) => (
            <a href={a.href} class="article-card">
              <div class="article-card-tag">{a.tag}</div>
              <div class="article-card-title">{a.title}</div>
              <p class="article-card-desc">{a.desc}</p>
              <div class="article-card-link">{a.label}</div>
            </a>
          ))}
        </div>
      </div>

    </div><!-- /wide-wrap -->

    <div class="article"><!-- resume narrow -->

      <!-- Klook Section -->
      <h2 id="klook-offers">Klook 省錢情報</h2>
      <p>
        整理 2026 年最新各大銀行 Klook 刷卡折扣。
        透過下方連結進入 Klook，結帳輸入優惠碼即享折扣。
      </p>

      <div class="coupon-grid">
        {offers.map((o) => (
          <div class="coupon-card">
            <div class="coupon-top">
              <div>
                <div class="coupon-bank">{o.bank}</div>
                <div class="coupon-title">{o.title}</div>
              </div>
              <span class="coupon-badge">{o.badge}</span>
            </div>
            <div class="coupon-bottom">
              <div>
                <div class="coupon-label">優惠碼</div>
                <code class="coupon-code">{o.code}</code>
              </div>
            </div>
            <a href={AFFILIATE_LINK} target="_blank" rel="noopener noreferrer" class="coupon-btn">
              前往 Klook 使用 →
            </a>
          </div>
        ))}
      </div>

      <div class="tip-box">
        <div class="tip-title">注意事項</div>
        <p style="margin:0;font-size:14px;color:var(--ink-light);">
          優惠數量有限，依結帳順序為準。各優惠碼適用商品與低消門檻不同，請詳閱各活動說明。
          優惠期限以 Klook 官方公告為準。本頁含聯盟行銷連結，透過連結購買不影響你的價格。
        </p>
      </div>

      <!-- Email Subscribe -->
      <div class="subscribe-box">
        <div class="subscribe-inner">
          <div class="subscribe-icon">✉</div>
          <h3 class="subscribe-title">省錢情報，直接送到你的信箱</h3>
          <p class="subscribe-desc">新優惠碼、Klook 限時折扣、高鐵票攻略更新——不定期整理，不灌水。</p>
          <form
            name="newsletter"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="subscribe-form"
            id="subscribe-form"
          >
            <input type="hidden" name="form-name" value="newsletter" />
            <p style="display:none;"><label>不要填：<input name="bot-field" /></label></p>
            <div class="subscribe-row">
              <input
                type="email"
                name="email"
                placeholder="your@email.com"
                required
                class="subscribe-input"
              />
              <button type="submit" class="subscribe-btn">訂閱 →</button>
            </div>
            <p class="subscribe-note">不會轉賣你的 email，任何時候都可以取消訂閱。</p>
          </form>
          <div class="subscribe-success" id="subscribe-success" hidden>
            <p>✓ 已收到！我會把最新情報寄給你。</p>
          </div>
        </div>
      </div>

    </div>

    <!-- Footer -->
    <footer class="site-footer">
      <strong>重來的旅人</strong> · 把踩過的坑，變成你的攻略<br>
      <div class="footer-nav">
        <a href="/esim">eSIM 比較</a>
        <a href="/esim/japan">日本 eSIM</a>
        <a href="/esim/korea">韓國 eSIM</a>
        <a href="/japan-guide">日本攻略</a>
        <a href="/korea-guide">韓國攻略</a>
        <a href="/thsr-guide">高鐵省錢</a>
        <a href="/story">作者故事</a>
        <a href="/#klook-offers">Klook 優惠碼</a>
      </div>
      <span style="display:block;margin-top:10px;">自媒體行銷 · 越南生活 10 年 · 現在重新出發</span>
    </footer>

  </div>
</BlogLayout>

<script>
  var form = document.getElementById('subscribe-form');
  var success = document.getElementById('subscribe-success');
  if (form && success) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var data = new FormData(form as HTMLFormElement);
      await fetch('/', { method: 'POST', body: data });
      (form as HTMLElement).hidden = true;
      (success as HTMLElement).hidden = false;
    });
  }
</script>

<style>
  .root {
    --ink: #1a1208;
    --ink-light: #4a3f2f;
    --paper: #faf8f3;
    --paper-warm: #f2ede0;
    --accent: #c0392b;
    --gold: #b8860b;
    --border: #d4c9b0;
    --serif: 'Noto Serif TC', serif;
    --sans: 'Noto Sans TC', sans-serif;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.8;
    font-size: 17px;
    min-height: 100vh;
  }

  /* Header */
  .site-header {
    border-bottom: 2px solid var(--ink);
    padding: 18px 0;
    text-align: center;
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .site-name {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-decoration: none;
  }
  .site-name span { color: var(--accent); }

  /* Hero */
  .hero {
    max-width: 740px;
    margin: 60px auto 0;
    padding: 0 24px;
  }
  .category-tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    border-left: 3px solid var(--accent);
    padding-left: 10px;
    margin-bottom: 20px;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 900;
    font-size: clamp(28px, 5vw, 44px);
    line-height: 1.35;
    margin-bottom: 20px;
  }
  .subtitle {
    font-size: 17px;
    color: var(--ink-light);
    margin-bottom: 32px;
    line-height: 1.75;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
    font-size: 13px;
    color: var(--ink-light);
  }
  .author-dot {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--serif);
    font-weight: 900;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .meta-author { font-weight: 500; font-size: 14px; color: var(--ink); }

  /* Article body */
  .article {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }
  .article p { margin-bottom: 1.4em; }

  h2 {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 26px;
    margin: 52px 0 16px;
    position: relative;
    padding-left: 16px;
  }
  h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 80%;
    background: var(--accent);
    border-radius: 2px;
  }

  /* Story box */
  .story-box {
    background: var(--paper-warm);
    border-left: 4px solid var(--accent);
    padding: 24px 28px;
    margin: 0 0 40px;
    border-radius: 0 6px 6px 0;
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink-light);
    line-height: 1.9;
  }
  .story-box strong { color: var(--ink); font-weight: 600; }

  /* Wide two-column layout */
  .wide-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 56px;
    align-items: start;
  }
  .section-col { padding-bottom: 48px; }
  .section-col h2 { margin-top: 52px; }
  .section-desc { margin-bottom: 0; }

  /* Article cards */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin: 20px 0 0;
  }
  .article-card {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 22px 20px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .article-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 16px rgba(192,57,43,0.08);
  }
  .article-card-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .article-card-title {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 16px;
    line-height: 1.45;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .article-card-desc {
    font-size: 13.5px;
    color: var(--ink-light);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 16px !important;
  }
  .article-card-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    margin-top: auto;
  }

  /* Coupon cards */
  .coupon-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    margin: 28px 0 32px;
  }
  .coupon-card {
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 18px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--paper);
  }
  .coupon-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }
  .coupon-bank { font-size: 11px; color: var(--ink-light); margin-bottom: 4px; }
  .coupon-title { font-size: 14px; font-weight: 500; color: var(--ink); line-height: 1.4; }
  .coupon-badge {
    flex-shrink: 0;
    background: #fde8e8;
    color: #8b1a1a;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 10px;
    white-space: nowrap;
  }
  .coupon-bottom { display: flex; align-items: center; justify-content: space-between; }
  .coupon-label { font-size: 11px; color: var(--ink-light); margin-bottom: 4px; }
  .coupon-code {
    background: var(--paper-warm);
    color: var(--ink);
    font-family: monospace;
    font-size: 13px;
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: 0.06em;
  }
  .coupon-btn {
    display: block;
    text-align: center;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--serif);
    font-weight: 600;
    font-size: 13px;
    padding: 10px;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .coupon-btn:hover { background: #2c1f0f; }

  /* Tip box */
  .tip-box {
    border: 1.5px solid var(--border);
    border-radius: 6px;
    padding: 20px 24px;
    margin: 32px 0 0;
  }
  .tip-title {
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--gold);
