---
import BlogLayout from '../layouts/BlogLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import SiteNav from '../components/SiteNav.astro';
import { prepArticles, travelArticles, esimArticles, lifeArticles } from '../data/articles.js';
---

<BlogLayout
  title="重來的旅人｜久久才出國一次的小資旅人：出國準備、旅遊省錢與越南避坑筆記"
  description="寫給久久才出國一次的小資旅人：出國前行李清單與必備小物、日本／韓國／越南旅遊攻略、越南在地避坑、高鐵與 Klook 省錢，還有出國上網方案整理。把踩過的坑，變成你的攻略。"
  keywords="出國準備, 第一次出國行李清單, 越南旅遊, 越南必備小物, 旅遊省錢, 出國上網, eSIM, 重來的旅人"
  ogImage="/esim-cover.jpg"
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet" />

  <div class="root">

    <!-- Header -->
    <SiteNav />

    <!-- Hero -->
    <div class="hero">
      <div class="category-tag">關於這個網站</div>
      <h1>前半生跌了很多跤，<br>現在把坑整理給你</h1>
      <p class="subtitle">
        我在越南工廠當過副總、養蝦失敗、跑過 Uber、父親走了之後才真正開始重新出發。<br>
        這個網站，是一個 40 幾歲台灣男人寫給自己、也寫給你的筆記。
      </p>
      <div class="meta">
        <div class="author-dot">旅</div>
        <div>
          <div class="meta-author">重來的旅人</div>
          <div>越南生活 10 年 · 自媒體行銷 · 重新出發</div>
        </div>
      </div>
    </div>

    <!-- Author Story -->
    <div class="article">
      <div class="story-box">
        <strong>我不是什麼旅遊達人，也沒有光鮮亮麗的履歷。</strong><br><br>
        我是家裡文具工廠的第二代。國中叛逆、KTV 鬧事住院，被送去加拿大九個月帶回來。
        後來去越南幫父親管廠，擔任副總一待就是十年。
        養蝦失敗、環保藥劑事業失敗，靠父親收拾殘局。
        2018 年回台灣，工廠被拍賣，跑起了 Uber。
        外婆走了，父親肺癌末期也走了。那是人生最深的失落。<br><br>
        直到遇見主耶穌，重新找回了方向。
        這個網站，是我把這些年踩過的坑，整理成對你有用的東西。
        <br><br>
        <a href="/story" style="color:var(--accent);font-weight:600;font-size:15px;">→ 看完整的故事</a>
      </div>

    </div><!-- /article (story box) -->

    <!-- Intro content: 提升首頁原創內容與 E-E-A-T -->
    <div class="article intro-content">
      <h2>這個網站幫誰？</h2>
      <p>
        這個網站只寫給一種人：<strong>久久才出國一次的小資旅人。</strong>
        不是每個月飛的空中飛人，而是可能上次出國已經是好幾年前、規矩和習慣都變了、
        最怕「漏帶東西」和「被當盤子坑」的你。
      </p>
      <p>
        我在越南住了十年，從工廠副總到回台灣跑 Uber，這些年自己訂票、自己找路、自己被海關和路邊計程車坑過，
        才慢慢摸出哪些東西非帶不可、哪些錢該省、哪些坑要避。這個網站，就是把那些教訓寫成你能直接拿去用的筆記。
      </p>
      <p>內容分成幾塊，你可以從上方選單或下面的卡片進去：</p>
      <ul class="intro-list">
        <li>
          <strong>出國前準備</strong>：第一次出國行李清單、必備小物、防曬防蚊、防盜包、轉接頭——
          久久才飛一次最容易漏掉的，都先幫你列好。
        </li>
        <li>
          <strong>旅遊攻略與越南避坑</strong>：不是觀光局那種「十大必去」，而是機場、叫車、親子、貴賓室，
          住越南十年累積下來的真實經驗。
        </li>
        <li>
          <strong>旅遊省錢</strong>：高鐵怎麼買最便宜、各家銀行 Klook 刷卡折扣、信用卡海外回饋怎麼疊。
        </li>
        <li>
          <strong>出國上網 eSIM</strong>：原生 vs 漫遊差在哪、哪家有中文客服、安裝失敗怎麼救。
          完全不業配，<strong>依官方規格與使用情境整理，不是每張都親自實測，我會誠實標註</strong>。
        </li>
      </ul>
      <p class="intro-note">
        說明一下：本站部分連結是聯盟行銷連結，你透過它們購買，我會拿到一點分潤，但<strong>不會影響你的價格</strong>。
        我只放自己用過、或評估後真心覺得對你有幫助的東西。更完整的揭露寫在
        <a href="/privacy">隱私權政策</a>，想多認識我可以看
        <a href="/about">關於我</a>。
      </p>
    </div>

    <!-- 出國前準備（首頁第一主軸）-->
    <div class="home-section">
      <h2>久久才出國一次，先看這些</h2>
      <p class="section-desc">出發前最容易漏掉的行李、必備小物與打包眉角，都整理在這裡。</p>
      <div class="home-grid">
        {prepArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- 旅遊攻略與越南避坑 -->
    <div class="home-section">
      <h2>旅遊攻略與越南避坑</h2>
      <p class="section-desc">住越南十年的真實經驗——機場通關、叫車、親子、貴賓室、夜遊與日韓行程規劃。</p>
      <div class="home-grid">
        {travelArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- 出國上網 eSIM（後段，屬出國準備的一項，非主角）-->
    <div class="home-section">
      <h2>出國上網 eSIM / 方案</h2>
      <p class="section-desc">上網只是出國準備的其中一項。以下依各家官方規格、線路類型與使用情境整理，不業配、非每張親自實測。</p>
      <a href="/esim-quiz" class="quiz-cta">🧭 30 秒測出你該用哪種上網方案 →</a>
      <div class="home-grid">
        {esimArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <!-- 省錢工具：單一導引卡，首頁不直接列優惠碼與外部連結 -->
    <div class="article">
      <h2>旅行省錢工具</h2>
      <p>
        出國訂門票、交通和行程前，記得先看一下手上的信用卡有沒有折扣。
        我把高鐵、Klook、票券、信用卡的省錢資訊整理成獨立頁，會不定期更新——首頁就不列一堆優惠碼和外部連結了。
      </p>
      <a href="/klook-deals" class="tool-card">
        <div class="tool-card-title">Klook 銀行優惠碼整理</div>
        <div class="tool-card-desc">各大信用卡的 Klook 刷卡折扣、折扣型 vs 回饋型怎麼分、怎麼挑卡，一頁看懂。</div>
        <div class="tool-card-link">看 Klook 省錢整理 →</div>
      </a>
    </div>

    <!-- Life notes -->
    <div class="home-section">
      <h2>人生筆記</h2>
      <p class="section-desc">旅遊與省錢之外，偶爾也寫一點中年重新出發的體悟與思考。</p>
      <div class="home-grid life-grid">
        {lifeArticles.map((a) => (
          <a href={a.href} class="article-card">
            <div class="article-card-tag">{a.tag}</div>
            <div class="article-card-title">{a.title}</div>
            <p class="article-card-desc">{a.desc}</p>
            <div class="article-card-link">{a.label}</div>
          </a>
        ))}
      </div>
    </div>

    <div class="article"><!-- resume narrow -->
      <!-- Social Links -->
      <SocialLinks
        heading="追蹤我｜Follow Me"
        subheading="IG、FB、YouTube 上會分享更多旅遊踩坑筆記與省錢情報"
      />
    </div>

    <!-- Footer -->
    <footer class="site-footer">
      <strong>重來的旅人</strong> · 把踩過的坑，變成你的攻略<br>
      <div class="footer-nav">
        <a href="/esim">eSIM 比較</a>
        <a href="/esim/japan">日本 eSIM</a>
        <a href="/esim/korea">韓國 eSIM</a>
        <a href="/esim/china">中國 eSIM</a>
        <a href="/esim/china-routing-2026">eSIM 封包送中爭議</a>
        <a href="/japan-guide">日本攻略</a>
        <a href="/korea-guide">韓國攻略</a>
        <a href="/vietnam-guide">越南攻略</a>
        <a href="/esim/saigon-airport-sim">胡志明機場 SIM</a>
        <a href="/vietnam-jcb-lounge">越南貴賓室</a>
        <a href="/kids-travel-guide">親子旅遊</a>
        <a href="/thsr-guide">高鐵省錢</a>
        <a href="/about">關於</a>
        <a href="/story">作者故事</a>
        <a href="/contact">聯絡我</a>
        <a href="/klook-deals">Klook 優惠碼</a>
        <a href="/life-restart-naval">人生筆記</a>
        <a href="/services">站長服務</a>
        <a href="/privacy">隱私權政策</a>
      </div>
      <span style="display:block;margin-top:10px;">自媒體行銷 · 越南生活 10 年 · 現在重新出發</span>
    </footer>

  </div>
</BlogLayout>

<script>
  var form = document.getElementById('subscribe-form');
  var success = document.getElementById('subscribe-success');
  if (form && success) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var data = new FormData(form as HTMLFormElement);
      await fetch('/', { method: 'POST', body: data });
      (form as HTMLElement).hidden = true;
      (success as HTMLElement).hidden = false;
    });
  }
</script>

<style>
  .root {
    --ink: #1a1208;
    --ink-light: #4a3f2f;
    --paper: #faf8f3;
    --paper-warm: #f2ede0;
    --accent: #c0392b;
    --gold: #b8860b;
    --border: #d4c9b0;
    --serif: 'Noto Serif TC', serif;
    --sans: 'Noto Sans TC', sans-serif;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.8;
    font-size: 17px;
    min-height: 100vh;
  }

  /* Header */
  .site-header {
    border-bottom: 2px solid var(--ink);
    padding: 18px 0;
    text-align: center;
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .site-name {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 20px;
    letter-spacing: 0.12em;
    color: var(--ink);
    text-decoration: none;
  }
  .site-name span { color: var(--accent); }

  /* Hero */
  .hero {
    max-width: 740px;
    margin: 60px auto 0;
    padding: 0 24px;
  }
  .category-tag {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    border-left: 3px solid var(--accent);
    padding-left: 10px;
    margin-bottom: 20px;
  }
  h1 {
    font-family: var(--serif);
    font-weight: 900;
    font-size: clamp(28px, 5vw, 44px);
    line-height: 1.35;
    margin-bottom: 20px;
  }
  .subtitle {
    font-size: 17px;
    color: var(--ink-light);
    margin-bottom: 32px;
    line-height: 1.75;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
    font-size: 13px;
    color: var(--ink-light);
  }
  .author-dot {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--serif);
    font-weight: 900;
    font-size: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .meta-author { font-weight: 500; font-size: 14px; color: var(--ink); }

  /* Article body */
  .article {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }
  .article p { margin-bottom: 1.4em; }

  h2 {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 26px;
    margin: 52px 0 16px;
    position: relative;
    padding-left: 16px;
  }
  h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    width: 4px;
    height: 80%;
    background: var(--accent);
    border-radius: 2px;
  }

  /* Story box */
  .story-box {
    background: var(--paper-warm);
    border-left: 4px solid var(--accent);
    padding: 24px 28px;
    margin: 0 0 40px;
    border-radius: 0 6px 6px 0;
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink-light);
    line-height: 1.9;
  }
  .story-box strong { color: var(--ink); font-weight: 600; }

  /* Intro content block */
  .intro-content { padding-bottom: 0; }
  .intro-content h2 { margin-top: 8px; }
  .intro-content p { font-size: 16px; color: var(--ink-light); }
  .intro-content strong { color: var(--ink); font-weight: 600; }
  .intro-list { margin: 0 0 1.4em; padding-left: 0; list-style: none; }
  .intro-list li {
    font-size: 15.5px;
    color: var(--ink-light);
    line-height: 1.8;
    padding: 14px 0 14px 18px;
    border-left: 3px solid var(--border);
    margin-bottom: 12px;
  }
  .intro-list li strong { color: var(--ink); }
  .intro-note {
    font-size: 14px;
    color: var(--ink-light);
    background: var(--paper-warm);
    border-radius: 6px;
    padding: 16px 20px;
  }
  .intro-note a { color: var(--accent); }

  /* Life notes section */
  .life-section { padding-top: 0; padding-bottom: 24px; }
  .life-section h2 { margin-top: 8px; }
  .life-grid { grid-template-columns: 1fr; max-width: 620px; }

  /* Wide two-column layout */
  .wide-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 56px;
    align-items: start;
  }
  .section-col { padding-bottom: 48px; }
  .section-col h2 { margin-top: 52px; }
  .section-desc { margin-bottom: 0; }

  .quiz-cta {
    display: inline-block;
    margin: 16px 0 0;
    padding: 12px 18px;
    border: 1.5px solid var(--accent);
    border-radius: 8px;
    background: #fef9f5;
    color: var(--accent);
    font-weight: 600;
    font-size: 14.5px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .quiz-cta:hover { background: #fbeee6; }

  /* Home full-width sections (出國前準備 / 旅遊 / eSIM / 人生筆記) */
  .home-section { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .home-section > h2 { margin-top: 52px; }
  .home-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
    margin: 20px 0 8px;
  }
  .home-grid.life-grid { grid-template-columns: 1fr; max-width: 640px; }

  /* Single tool card (省錢工具導引，取代首頁優惠碼明細) */
  .tool-card {
    display: block;
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 22px 24px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, box-shadow 0.15s;
    margin-top: 8px;
  }
  .tool-card:hover { border-color: var(--accent); box-shadow: 0 4px 16px rgba(192,57,43,0.08); }
  .tool-card-title { font-family: var(--serif); font-weight: 900; font-size: 18px; margin-bottom: 8px; color: var(--ink); }
  .tool-card-desc { font-size: 14px; color: var(--ink-light); line-height: 1.7; margin-bottom: 12px; }
  .tool-card-link { font-size: 14px; font-weight: 500; color: var(--accent); }

  /* Article cards */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin: 20px 0 0;
  }
  .article-card {
    display: flex;
    flex-direction: column;
    border: 2px solid var(--border);
    border-radius: 8px;
    padding: 22px 20px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .article-card:hover {
    border-color: var(--accent);
    box-shadow: 0 4px 16px rgba(192,57,43,0.08);
  }
  .article-card-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .article-card-title {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 16px;
    line-height: 1.45;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .article-card-desc {
    font-size: 13.5px;
    color: var(--ink-light);
    line-height: 1.7;
    flex: 1;
    margin-bottom: 16px !important;
  }
  .article-card-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    margin-top: auto;
  }

  /* Tip box */
  .tip-box {
    border: 1.5px solid var(--border);
    border-radius: 6px;
    padding: 20px 24px;
    margin: 32px 0 0;
  }
  .tip-title {
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  /* Subscribe box */
  .subscribe-box {
    margin: 56px 0 0;
    border: 2px solid var(--ink);
    border-radius: 8px;
    overflow: hidden;
  }
  .subscribe-inner {
    background: var(--ink);
    padding: 36px 40px;
    text-align: center;
    color: var(--paper);
  }
  .subscribe-icon { font-size: 28px; margin-bottom: 12px; }
  .subscribe-title {
    font-family: var(--serif);
    font-weight: 900;
    font-size: 22px;
    color: var(--paper);
    margin-bottom: 10px;
  }
  .subscribe-desc { font-size: 15px; color: #d4c9b0; margin-bottom: 24px; line-height: 1.6; }
  .subscribe-form { max-width: 440px; margin: 0 auto; }
  .subscribe-row { display: flex; gap: 10px; }
  .subscribe-input {
    flex: 1;
    font-family: var(--sans);
    font-size: 15px;
    padding: 12px 16px;
    border: 1.5px solid #4a3f2f;
    border-radius: 4px;
    background: #2c1f0f;
    color: var(--paper);
    outline: none;
    transition: border-color 0.15s;
  }
  .subscribe-input:focus { border-color: var(--accent); }
  .subscribe-input::placeholder { color: #6b5a46; }
  .subscribe-btn {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 15px;
    padding: 12px 24px;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    white-space: nowrap;
