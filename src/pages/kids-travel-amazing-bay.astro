---
import SocialLinks from '../components/SocialLinks.astro';

const title = "帶女兒回越南：The Amazing Bay 神奇海灣水樂園｜邊和越南最大水樂園｜重來的旅人";
const description = "The Amazing Bay（神奇海灣）是越南最大的水上樂園，就在邊和市，距離 The Mira 飯店 Grab 約 15 分鐘。一個住越南 10 年的台灣爸爸，紀錄家人去玩造浪池、拍 Tornado，以及在現場買票才發現台灣 Klook 訂便宜一半的踩雷實話。";
const canonical = "https://comebacktraveler.com/kids-travel-amazing-bay";
const LINK_KLOOK = 'https://onelink.one/s/eoBIW';
const LINK_KKDAY = 'https://onelink.one/s/SON7H';
