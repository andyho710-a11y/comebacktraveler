---
import SocialLinks from '../components/SocialLinks.astro';

const title = "日本自由行完整攻略 2026｜東京、京都、大阪行程規劃";
const description = "從東京到京阪奈，一個在越南住過 10 年、踩過無數坑的台灣人，把日本自由行的行程、省錢技巧、Klook 值得訂的活動整理成這篇。";
const canonical = "https://comebacktraveler.com/japan-guide";
const LINK_DISNEY = 'https://onelink.one/s/C0O6S';
const LINK_FUJISAN = 'https://afflink.one/s/PvT51';
const LINK_KIMONO = 'https://onelink.one/s/NYWXk';
const LINK_USJ = 'https://linkgo.one/s/Jo3ZM';
const LINK_JRPASS = 'https://linkgo.one/s/fK2k4';
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": canonical,
    "author": { "@type": "Person", "name": "重來的旅人" },
    "publisher": { "@type": "Organization", "name": "重來的旅人", "url": "https://comebacktraveler.com" },
    "dateModified": "2026-04-26"
  })} />
  <style>
    :root {
      --ink: #1a1208;
      --ink-light: #4a3f2f;
      --paper: #faf8f3;
      --paper-warm: #f2ede0;
      --accent: #c0392b;
      --gold: #b8860b;
      --border: #d4c9b0;
      --serif: 'Noto Serif TC', serif;
      --sans: 'Noto Sans TC', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--paper); color: var(--ink); font-family: var(--sans); line-height: 1.8; font-size: 17px; }

    .site-header { border-bottom: 2px solid var(--ink); padding: 18px 0; text-align: center; background: var(--paper); position: sticky; top: 0; z-index: 100; }
    .site-name { font-family: var(--serif); font-weight: 900; font-size: 20px; letter-spacing: 0.12em; color: var(--ink); text-decoration: none; }
    .site-name span { color: var(--accent); }

    .hero { max-width: 740px; margin: 60px auto 0; padding: 0 24px; }
    .category-tag { font-size: 12px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); border-left: 3px solid var(--accent); padding-left: 10px; margin-bottom: 20px; }
    h1 { font-family: var(--serif); font-weight: 900; font-size: clamp(26px, 5vw, 42px); line-height: 1.35; margin-bottom: 20px; }
    .subtitle { font-size: 17px; color: var(--ink-light); margin-bottom: 32px; line-height: 1.7; }
    .meta { display: flex; align-items: center; gap: 20px; padding: 16px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-bottom: 48px; font-size: 13px; color: var(--ink-light); }
    .author-dot { width: 40px; height: 40px; border-radius: 50%; background: var(--ink); color: var(--paper); font-family: var(--serif); font-weight: 900; font-size: 15px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .meta-author { font-weight: 500; font-size: 14px; color: var(--ink); }

    .article { max-width: 740px; margin: 0 auto; padding: 0 24px 80px; }
    .story-box { background: var(--paper-warm); border-left: 4px solid var(--accent); padding: 24px 28px; margin: 40px 0; border-radius: 0 6px 6px 0; font-family: var(--serif); font-size: 16px; color: var(--ink-light); line-height: 1.9; }
    .story-box strong { color: var(--ink); font-weight: 600; }
    p { margin-bottom: 1.4em; }
    h2 { font-family: var(--serif); font-weight: 900; font-size: 26px; margin: 52px 0 16px; position: relative; padding-left: 16px; }
    h2::before { content: ''; position: absolute; left: 0; top: 4px; width: 4px; height: 80%; background: var(--accent); border-radius: 2px; }
    h3 { font-family: var(--serif); font-weight: 700; font-size: 20px; margin: 36px 0 10px; }

    .city-section { border: 1.5px solid var(--border); border-radius: 8px; padding: 28px 32px; margin: 32px 0; }
    .city-label { font-size: 11px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--ink-light); margin-bottom: 6px; }
    .city-name { font-family: var(--serif); font-weight: 900; font-size: 22px; margin-bottom: 16px; color: var(--ink); }
    .spot-list { list-style: none; padding: 0; margin: 16px 0; }
    .spot-list li { padding: 8px 0; border-bottom: 1px solid var(--border); font-size: 15px; display: flex; align-items: flex-start; gap: 10px; }
    .spot-list li:last-child { border-bottom: none; }
    .spot-icon { color: var(--accent); font-weight: 600; flex-shrink: 0; }

    .klook-card { background: var(--paper-warm); border: 1.5px solid var(--border); border-radius: 6px; padding: 20px 24px; margin: 20px 0; }
    .klook-label { font-size: 11px; font-weight: 500; letter-spacing: 0.12em; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; }
    .klook-title { font-family: var(--serif); font-weight: 700; font-size: 16px; margin-bottom: 8px; }
    .klook-why { font-size: 14px; color: var(--ink-light); margin-bottom: 12px; }
    .klook-btn { display: inline-block; background: var(--accent); color: #fff; font-family: var(--serif); font-weight: 600; font-size: 14px; padding: 10px 22px; border-radius: 4px; text-decoration: none; }

    .tip-box { border: 1.5px solid var(--border); border-radius: 6px; padding: 20px 24px; margin: 32px 0; }
    .tip-title { font-weight: 500; font-size: 12px; letter-spacing: 0.12em; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; }

    .season-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin: 24px 0; }
    .season-card { border: 1.5px solid var(--border); border-radius: 6px; padding: 16px 18px; }
    .season-name { font-family: var(--serif); font-weight: 700; font-size: 15px; margin-bottom: 6px; }
    .season-desc { font-size: 13px; color: var(--ink-light); line-height: 1.6; margin: 0; }

    .internal-links { margin: 52px 0 0; padding: 28px 0; border-top: 1px solid var(--border); display: flex; gap: 20px; flex-wrap: wrap; }
    .internal-links a { color: var(--accent); text-decoration: none; font-size: 15px; font-weight: 500; }
    .internal-links a:hover { text-decoration: underline; }

    footer { border-top: 2px solid var(--ink); padding: 40px 24px; text-align: center; font-size: 13px; color: var(--ink-light); }
    .footer-nav { display: flex; justify-content: center; flex-wrap: wrap; gap: 6px 20px; margin-top: 14px; }
    .footer-nav a { color: var(--accent); text-decoration: none; font-size: 13px; }

    .comment-section { margin-top: 60px; padding-top: 40px; border-top: 1px solid var(--border); }
    .comment-form { margin-top: 24px; display: flex; flex-direction: column; gap: 20px; }
    .hidden { display: none; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-size: 13px; font-weight: 500; color: var(--ink-light); }
    .required { color: var(--accent); }
    .form-group input, .form-group textarea { font-family: var(--sans); font-size: 15px; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 4px; background: var(--paper); color: var(--ink); outline: none; transition: border-color 0.15s; resize: vertical; }
    .form-group input:focus, .form-group textarea:focus { border-color: var(--ink); }
    .form-group input::placeholder, .form-group textarea::placeholder { color: #b0a898; }
    .form-footer { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .form-note { font-size: 12px; color: #999; margin: 0; }
    .submit-btn { font-family: var(--serif); font-weight: 600; font-size: 15px; padding: 12px 32px; background: var(--ink); color: var(--paper); border: none; border-radius: 4px; cursor: pointer; transition: background 0.15s; }
    .submit-btn:hover { background: #2c1f0f; }
    .form-success { margin-top: 20px; padding: 18px 24px; background: #d5e8d4; border-radius: 4px; }
    .form-success p { margin: 0; color: #27611b; font-size: 15px; font-weight: 500; }

    @media (max-width: 600px) {
      .hero, .article { padding: 0 16px; }
      .city-section { padding: 20px; }
      .season-grid { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
      .form-footer { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

<header class="site-header">
  <a href="/" class="site-name">重來的<span>旅人</span></a>
</header>

<div class="hero">
  <div class="category-tag">日本自由行 · 行程攻略 2026</div>
  <h1>日本自由行完整攻略 2026<br>東京、京都、大阪<br>行程規劃全整理</h1>
  <p class="subtitle">
    不是觀光局廣告，是一個在越南住了十年、跑遍東南亞的台灣人，<br>
    第一次認真整理日本旅遊的心得。哪裡值得去、哪裡可以省、Klook 什麼時候訂最划算。
  </p>
  <div class="meta">
    <div class="author-dot">旅</div>
    <div>
      <div class="meta-author">重來的旅人</div>
      <div>2026 年 4 月更新 · 越南生活 10 年 · 現在重新出發</div>
    </div>
  </div>
</div>

<article class="article">

  <div class="story-box">
    <strong>我不是日本通，但我知道什麼感覺叫做「踩坑」。</strong><br><br>
    在越南工廠十年，每次旅行都是自己做功課、自己買票、自己找路。
    沒有行程秘書，沒有旅行社。學到的事情就是：提前訂、比價、找到一條最不費力的路。<br><br>
    這篇是我替自己整理的日本旅遊筆記。你直接拿去用。
  </div>

  <h2>什麼季節去日本最值得？</h2>
  <p>日本四季都有亮點，但「值得」這件事要看你的優先順序：</p>

  <div class="season-grid">
    <div class="season-card">
      <div class="season-name">春季（3–4 月）</div>
      <p class="season-desc">賞櫻旺季，人潮和住宿費雙雙暴漲。提早 2–3 個月訂房，Klook 景點票提前鎖定。</p>
    </div>
    <div class="season-card">
      <div class="season-name">夏季（7–8 月）</div>
      <p class="season-desc">熱且濕，但有祭典和煙火大會。避開 Obon（8 月中）旺季，住宿費會回落。</p>
    </div>
    <div class="season-card">
      <div class="season-name">秋季（10–11 月）</div>
      <p class="season-desc">紅葉季。氣候舒適，台灣人最多，京都尤其爆。建議平日入住京都外圍。</p>
    </div>
    <div class="season-card">
      <div class="season-name">冬季（12–2 月）</div>
      <p class="season-desc">滑雪、泡湯。北海道、長野最強。機票住宿淡季，只要不怕冷就是甜蜜期。</p>
    </div>
  </div>

  <h2>東京：先搞定這幾個區就夠了</h2>

  <div class="city-section">
    <div class="city-label">Day 1–2 首選</div>
    <div class="city-name">東京</div>
    <ul class="spot-list">
      <li><span class="spot-icon">▶</span><div><strong>淺草寺 + 仲見世通</strong>：老東京風情，早上 8 點前到才能體驗清靜。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>上野公園 + 博物館</strong>：免費入場，國立西洋美術館是世界遺產。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>新宿</strong>：購物、居酒屋、歌舞伎町，晚上最有活力的地方。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>渋谷 Scramble Square 展望台</strong>：高空俯瞰澀谷十字路口，比東京鐵塔性價比高。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>築地外市場</strong>：早上 9 點出門，現場吃海鮮早餐，不用擠豐洲市場。</div></li>
    </ul>
  </div>

  <div class="klook-card">
    <div class="klook-label">Klook 推薦預訂</div>
    <div class="klook-title">東京迪士尼樂園 / 迪士尼海洋門票</div>
    <p class="klook-why">旺季現場排隊買票等待 30–60 分鐘，Klook 電子票直接入場。節假日前價格不漲，但早訂早安心。</p>
    <a href={LINK_DISNEY} target="_blank" rel="noopener sponsored" class="klook-btn">Klook 看價格 →</a>
  </div>

  <div class="klook-card">
    <div class="klook-label">Klook 推薦預訂</div>
    <div class="klook-title">東京一日巴士觀光 / 富士山一日遊</div>
    <p class="klook-why">自己開車或搭 JR 到富士山五合目需要換乘 3–4 次，Klook 包車接送省掉所有規劃時間，來回含午餐。</p>
    <a href={LINK_FUJISAN} target="_blank" rel="noopener sponsored" class="klook-btn">Klook 看行程 →</a>
  </div>

  <h2>京都：不要跟著人潮跑</h2>

  <div class="city-section">
    <div class="city-label">古都精華</div>
    <div class="city-name">京都</div>
    <ul class="spot-list">
      <li><span class="spot-icon">▶</span><div><strong>伏見稻荷大社</strong>：千鳥居迷宮，早上 6 點到才沒人。這是免費的，不用搶票。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>嵐山竹林</strong>：10 分鐘就走完，但日出時分的光線讓人忘記這是景點。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>金閣寺</strong>：外觀 15 分鐘看完，但那個金色真的值得。提前上 Klook 訂票，現場省 20 分鐘排隊。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>祇園花見小路</strong>：傍晚 5–7 點是黃金時間，偶爾能看到藝妓出門。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>哲學之道（春、秋限定）</strong>：賞櫻或紅葉時必去，日常期間就是普通散步小路。</div></li>
    </ul>
  </div>

  <div class="klook-card">
    <div class="klook-label">Klook 推薦預訂</div>
    <div class="klook-title">京都和服租借體驗</div>
    <p class="klook-why">穿和服走在祇園的體驗很難用其他方式複製。Klook 上有多家店可比價，含髮型設計，3–4 小時租借。</p>
    <a href={LINK_KIMONO} target="_blank" rel="noopener sponsored" class="klook-btn">Klook 比價 →</a>
  </div>

  <h2>大阪：吃飯型旅客的天堂</h2>

  <div class="city-section">
    <div class="city-label">美食 + 樂趣</div>
    <div class="city-name">大阪</div>
    <ul class="spot-list">
      <li><span class="spot-icon">▶</span><div><strong>道頓堀</strong>：大阪最熱鬧的街，章魚燒、串炸、大阪燒集中地。晚上 8 點最有生氣。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>黑門市場</strong>：早上 10–12 點是逛市場的最佳時間，現切鮪魚、現烤海鮮都有。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>大阪城</strong>：外觀壯觀，登頂可俯瞰整個大阪。建議平日早上去，人少很多。</div></li>
      <li><span class="spot-icon">▶</span><div><strong>心齋橋 + 美國村</strong>：購物中心 + 二手服飾，年輕文化集散地。</div></li>
    </ul>
  </div>

  <div class="klook-card">
    <div class="klook-label">Klook 推薦預訂</div>
    <div class="klook-title">環球影城（USJ）門票 + 快速通關</div>
    <p class="klook-why">USJ 旺季熱門項目排隊 2–3 小時是常態。Klook 有快速通關加購方案，且經常比官網便宜 5–10%。</p>
    <a href={LINK_USJ} target="_blank" rel="noopener sponsored" class="klook-btn">Klook 查票價 →</a>
  </div>

  <h2>省錢重點：交通票券怎麼選</h2>

  <div class="tip-box">
    <div class="tip-title">JR Pass vs 個別買票</div>
    <p style="margin:0;font-size:15px;">
      <strong>JR Pass 值得買的情況</strong>：行程跨越東京→京都→大阪，並且單趟以上使用新幹線。<br><br>
      <strong>不值得買的情況</strong>：只待東京或只待大阪。地鐵一日券 + IC 卡（Suica / ICOCA）往往更省。<br><br>
      計算方式：把你會搭的所有新幹線票價加總，超過 JR Pass 售價才划算。
    </p>
  </div>

  <div class="klook-card">
    <div class="klook-label">Klook 推薦預訂</div>
    <div class="klook-title">JR Pass 全國版 / 關西版 / Suica 儲值卡</div>
    <p class="klook-why">Klook 上的 JR Pass 售價通常等於官方定價，但可以在台灣就領票，省去日本現場排隊兌換的麻煩。Suica 也可以預先加值。</p>
    <a href={LINK_JRPASS} target="_blank" rel="noopener sponsored" class="klook-btn">Klook 買 JR Pass →</a>
  </div>

  <h2>出發前的清單</h2>
  <ul style="padding-left:20px;margin-bottom:1.4em;">
    <li style="margin-bottom:8px;"><strong>eSIM 上網</strong>：落地就有網路，不用換實體 SIM。<a href="/esim/japan" style="color:var(--accent);">日本 eSIM 推薦看這裡</a>。</li>
    <li style="margin-bottom:8px;"><strong>Suica / ICOCA 感應卡</strong>：幾乎所有地鐵、便利商店、自動販賣機都能用，出發前在 Klook 買好加值。</li>
    <li style="margin-bottom:8px;"><strong>必搶門票</strong>：迪士尼、USJ、藥師寺特別展、高需求活動，提早 1–2 個月在 Klook 預訂。</li>
    <li style="margin-bottom:8px;"><strong>住宿</strong>：京都旺季提前 60 天訂房，大阪可以晚一點，東京淡旺季差異大。</li>
    <li style="margin-bottom:0;"><strong>信用卡</strong>：帶一張有海外回饋的卡（如玉山 Pi 或台新 @GOGO），所有消費自動回饋 2–3%。</li>
  </ul>

  <div class="internal-links">
    <a href="/esim/japan">→ 日本 eSIM 推薦（落地就有網路）</a>
    <a href="/korea-guide">→ 韓國自由行攻略</a>
    <a href="/#klook-offers">→ Klook 優惠碼整理</a>
    <a href="/thsr-guide">→ 高鐵怎麼買最便宜</a>
  </div>

  <SocialLinks
    heading="追蹤我｜Follow Me"
    subheading="更多日本旅遊筆記與 Klook 優惠情報，會在 IG、FB、YouTube 同步分享"
  />

  <div class="comment-section">
    <h2 style="margin-top:0;">你有日本旅遊問題嗎？</h2>
    <p style="font-size:15px;color:var(--ink-light);">留言問我，或分享你踩過的坑</p>
    <form
      name="japan-guide-comments"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      class="comment-form"
      id="comment-form"
    >
      <input type="hidden" name="form-name" value="japan-guide-comments" />
      <p class="hidden"><label>不要填這個：<input name="bot-field" /></label></p>
      <div class="form-row">
        <div class="form-group">
          <label for="cf-name">名字 <span class="required">*</span></label>
          <input type="text" id="cf-name" name="name" placeholder="你的稱呼" required />
        </div>
        <div class="form-group">
          <label for="cf-email">Email <span class="required">*</span></label>
          <input type="email" id="cf-email" name="email" placeholder="your@email.com" required />
        </div>
      </div>
      <div class="form-group">
        <label for="cf-message">留言 <span class="required">*</span></label>
