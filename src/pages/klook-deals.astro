---
import SocialLinks from '../components/SocialLinks.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const title = "Klook 銀行優惠碼整理 2026｜各大信用卡刷卡折扣｜重來的旅人";
const description = "整理 2026 年各大銀行的 Klook 刷卡優惠碼與折扣：玉山國旅卡、中華郵政、新光、彰銀、中信 LINE Pay。附使用方式與注意事項，出國訂行程前先看一眼。";
const canonical = "https://comebacktraveler.com/klook-deals";

const AFFILIATE_LINK = 'https://onelink.one/s/Rkzvi';

const offers = [
  { bank: '玉山銀行公務人員國旅卡', title: '全站滿 $3,000 享 94 折', badge: '6% OFF', code: 'ESUNDC26Q294', validUntil: '2026/06/30' },
  { bank: '中華郵政 VISA 金融卡', title: '高鐵國旅聯票滿 $1,000 折 $100', badge: '$100 OFF', code: 'POSTHS268505', validUntil: '2026/06/30' },
  { bank: '新光銀行 Visa 卡', title: '海外商品 93 折', badge: '7% OFF', code: 'VSKB269305', validUntil: '2026/06/30' },
  { bank: '彰化銀行', title: '海外商品 95 折', badge: '5% OFF', code: 'CHB269505', validUntil: '2026/06/30' },
  { bank: '中國信託 LINE Pay Visa', title: '台港澳飯店 12% LINE POINTS 回饋', badge: '12% 回饋', code: 'CTBCLP26CH2', validUntil: '2026/12/31' },
];
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Klook優惠碼,Klook折扣,玉山國旅卡,中信LINE Pay,Klook刷卡優惠,2026" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="zh_TW" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "Klook 銀行優惠碼整理 2026｜各大信用卡刷卡折扣",
    "description": description,
    "url": canonical,
    "mainEntityOfPage": canonical,
    "inLanguage": "zh-TW",
    "datePublished": "2026-04-26",
    "dateModified": "2026-06-16",
    "author": { "@type": "Person", "name": "重來的旅人", "url": "https://comebacktraveler.com/about" },
    "publisher": { "@type": "Organization", "name": "重來的旅人", "url": "https://comebacktraveler.com" }
  })} />
  <style>
    :root {
      --ink: #1a1208;
      --ink-light: #4a3f2f;
      --paper: #faf8f3;
      --paper-warm: #f2ede0;
      --accent: #c0392b;
      --gold: #b8860b;
      --border: #d4c9b0;
      --serif: 'Noto Serif TC', serif;
      --sans: 'Noto Sans TC', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--paper); color: var(--ink); font-family: var(--sans); line-height: 1.8; font-size: 17px; }

    .hero { max-width: 740px; margin: 56px auto 0; padding: 0 24px; }
    .category-tag { font-size: 12px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); border-left: 3px solid var(--accent); padding-left: 10px; margin-bottom: 20px; }
    h1 { font-family: var(--serif); font-weight: 900; font-size: clamp(27px, 4.5vw, 40px); line-height: 1.4; margin-bottom: 20px; }
    .subtitle { font-size: 17px; color: var(--ink-light); margin-bottom: 36px; line-height: 1.75; }

    .article { max-width: 740px; margin: 0 auto; padding: 0 24px 80px; }
    .article p { margin-bottom: 1.4em; }
    h2 { font-family: var(--serif); font-weight: 900; font-size: 24px; margin: 48px 0 14px; position: relative; padding-left: 16px; }
    h2::before { content: ''; position: absolute; left: 0; top: 4px; width: 4px; height: 80%; background: var(--accent); border-radius: 2px; }
    strong { color: var(--ink); }
    .article a { color: var(--accent); }

    .coupon-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; margin: 28px 0 32px; }
    .coupon-card { border: 1.5px solid var(--border); border-radius: 8px; padding: 18px 20px; display: flex; flex-direction: column; gap: 12px; background: var(--paper); }
    .coupon-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 10px; }
    .coupon-bank { font-size: 11px; color: var(--ink-light); margin-bottom: 4px; }
    .coupon-title { font-size: 14px; font-weight: 500; color: var(--ink); line-height: 1.4; }
    .coupon-badge { flex-shrink: 0; background: #fde8e8; color: #8b1a1a; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 10px; white-space: nowrap; }
    .coupon-bottom { display: flex; align-items: center; justify-content: space-between; }
    .coupon-label { font-size: 11px; color: var(--ink-light); margin-bottom: 4px; }
    .coupon-code { display: inline-flex; align-items: center; gap: 8px; background: var(--paper-warm); color: var(--ink); font-family: monospace; font-size: 13px; padding: 4px 10px; border-radius: 4px; letter-spacing: 0.06em; border: 1px dashed var(--border); cursor: pointer; transition: background 0.15s, border-color 0.15s; }
    .coupon-code:hover { background: #ece3cf; border-color: var(--accent); }
    .coupon-code .copy-hint { font-family: var(--sans); font-size: 11px; letter-spacing: 0; color: var(--accent); font-weight: 500; }
    .coupon-code.copied { border-color: #1c5e15; }
    .coupon-code.copied .copy-hint { color: #1c5e15; }
    .coupon-expiry { font-size: 12px; color: var(--ink-light); white-space: nowrap; padding-left: 12px; }
    .coupon-btn { display: block; text-align: center; background: var(--ink); color: var(--paper); font-family: var(--serif); font-weight: 600; font-size: 13px; padding: 10px; border-radius: 4px; text-decoration: none; transition: background 0.15s; }
    .coupon-btn:hover { background: #2c1f0f; }

    .tip-box { border: 1.5px solid var(--border); border-radius: 6px; padding: 20px 24px; margin: 32px 0; }
    .tip-title { font-weight: 500; font-size: 12px; letter-spacing: 0.12em; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; }

    .internal-links { margin: 44px 0 0; padding-top: 28px; border-top: 1px solid var(--border); display: flex; gap: 20px; flex-wrap: wrap; }
    .internal-links a { color: var(--accent); text-decoration: none; font-size: 15px; font-weight: 500; }
    .internal-links a:hover { text-decoration: underline; }

    @media (max-width: 700px) {
      .hero, .article { padding: 0 18px; }
      .coupon-grid { grid-template-columns: 1fr; }
    }
  </style>
  <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2666904599101446" crossorigin="anonymous"></script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XW4LBK8PYF"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XW4LBK8PYF');
  </script>
</head>
<body>

<SiteNav />

<div class="hero">
  <div class="category-tag">省錢情報 · Klook 優惠碼</div>
  <h1>Klook 銀行優惠碼整理 2026</h1>
  <p class="subtitle">
    出國前訂門票、交通、行程，記得先看一眼這頁。<br>
    我把各大銀行信用卡的 Klook 刷卡折扣整理在這裡，會不定期更新。
  </p>
</div>

<article class="article">

  <p>
    很多人訂 Klook 行程時，忘了自己手上的信用卡其實有折扣或回饋。
    這頁整理 2026 年常見的銀行 Klook 優惠碼——<strong>進入 Klook、把商品加入購物車後，於結帳頁輸入對應優惠碼即可折抵</strong>。
    每張卡的適用商品、低消門檻和效期都不同，下單前請以 Klook 與發卡銀行的官方公告為準。
  </p>

  <h2>各銀行 Klook 優惠碼一覽</h2>

  <div class="coupon-grid">
    {offers.map((o) => (
      <div class="coupon-card">
        <div class="coupon-top">
          <div>
            <div class="coupon-bank">{o.bank}</div>
            <div class="coupon-title">{o.title}</div>
          </div>
          <span class="coupon-badge">{o.badge}</span>
        </div>
        <div class="coupon-bottom">
          <div>
            <div class="coupon-label">優惠碼</div>
            <button type="button" class="coupon-code copy-code" data-code={o.code} aria-label={`複製優惠碼 ${o.code}`}>
              <span class="code-text">{o.code}</span>
              <span class="copy-hint">複製</span>
            </button>
          </div>
          <div class="coupon-expiry">效期至 {o.validUntil}</div>
        </div>
        <a href={o.url ?? AFFILIATE_LINK} target="_blank" rel="noopener noreferrer sponsored" class="coupon-btn">
          前往 Klook 使用 →
        </a>
      </div>
    ))}
  </div>

  <div class="tip-box">
    <div class="tip-title">注意事項</div>
    <p style="margin:0;font-size:14px;color:var(--ink-light);">
      優惠數量有限，依結帳順序為準。各優惠碼適用商品與低消門檻不同，請詳閱各活動說明。
      優惠期限以 Klook 官方公告為準。本頁含聯盟行銷連結，透過連結購買不影響你的價格——
      完整揭露寫在 <a href="/privacy">隱私權政策</a>。
    </p>
  </div>

  <h2>怎麼用最划算</h2>
  <p>
    我自己的習慣是：先把要訂的東西（門票、機場接送、一日遊）放進購物車，
    再回來這頁對照手上的卡片——哪張折扣高就用哪張結帳。海外回饋型的卡（如中信 LINE Pay）
    和折扣型的卡（如玉山國旅卡）邏輯不同，金額大的時候值得花一分鐘比一下。
  </p>

  <div class="internal-links">
    <a href="/japan-guide">→ 日本自由行攻略</a>
    <a href="/korea-guide">→ 韓國自由行攻略</a>
    <a href="/thsr-guide">→ 高鐵怎麼買最便宜</a>
    <a href="/esim">→ eSIM 品牌比較</a>
  </div>

  <SocialLinks
    heading="追蹤我｜Follow Me"
    subheading="更多旅遊省錢情報，會在 IG、FB、YouTube 同步分享"
  />

</article>

<SiteFooter />

<script>
  // 一鍵複製優惠碼
  document.querySelectorAll('.copy-code').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      var code = btn.getAttribute('data-code') || '';
      try {
        await navigator.clipboard.writeText(code);
      } catch (err) {
        var ta = document.createElement('textarea');
        ta.value = code;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
      }
      var hint = btn.querySelector('.copy-hint');
      if (hint) {
        var prev = hint.textContent;
        hint.textContent = '已複製 ✓';
        btn.classList.add('copied');
        setTimeout(function () {
          hint.textContent = prev;
          btn.classList.remove('copied');
        }, 1600);
      }
    });
  });
</script>

</body>
</html>
