const title = "帶女兒第一次回越南：The Mira 五星飯店 + Lẩu Tôm 5 Ri 5 在地海鮮店｜重來的旅人";
const description = "帶女兒回胡志明市，住 The Mira Central Park 五星飯店，落地當晚就殺去當地人最愛的 Lẩu Tôm 5 Ri 5 海鮮店——一個住越南 10 年的台灣爸爸，分享「住高檔、吃在地」的親子旅遊心法。";
const canonical = "https://comebacktraveler.com/kids-travel-guide";
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
