import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ContentDisclaimer from '../components/ContentDisclaimer.astro';

const title = "越南自由行行李清單｜住越南十年，教你帶多少、怎麼裝、什麼上手提";
const description = "越南自由行行李怎麼打包？住越南十年的過來人，從帶多少、怎麼裝箱、手提行李 vs 託運怎麼分，整理出一份不超重、不漏帶、不被海關卡的越南行李清單。";
const canonical = "https://comebacktraveler.com/vietnam-packing-list";
const cover = "https://comebacktraveler.com/vietnam-airport-queue.jpg";

const shopeeUrl = "https://collshp.com/andyho8431/category/3834915?share_channel_code=6&view=storefront";

const faqs = [
  {
    q: "越南自由行帶幾公斤行李剛好？",
    a: "5 天行程，含回程戰利品大約 15–18 公斤很夠。越南衣物薄、當地好買，重點是回程預留空間給咖啡、零食這些伴手禮。",
  },
  {
    q: "行動電源可以帶上越南的飛機嗎？",
    a: "可以，但只能隨身手提、禁止託運，且容量需符合航空規定（一般 100Wh 以下無虞）。越南內陸航班檢查較嚴，務必放隨身包。",
  },
  {
    q: "越南需要帶轉接頭嗎？",
    a: "插座大多與台灣扁頭相容，不一定需要轉接頭。真正要注意的是電壓——越南 220V、台灣 110V，發熱電器要確認支援雙電壓。",
  },
];
