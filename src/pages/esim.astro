---
import BlogLayout from '../layouts/BlogLayout.astro';

const JOYTEL_LINK = 'https://afflink.one/s/zf2Z8';

const brands = [
  {
    name: 'JOYTEL',
    badges: [{ label: '台灣品牌', cls: 'badge-tw' }, { label: '首推', cls: 'badge-rec' }],
    coverage: '日、韓、東南亞、歐洲、美加',
    price: 'NT$299–799',
    priceNote: '原生/漫遊皆有',
    line: '原生線路',
    lineNote: 'Docomo/SoftBank/KDDI',
    hotspot: true,
    support: true,
    supportNote: 'LINE 全年無休',
    forWho: '台灣旅客、注重速度與客服',
    featured: true,
    tags: 'japan korea sea europe',
  },
  {
    name: 'DJB',
    badges: [{ label: '聲量 No.1', cls: 'badge-rec' }],
    coverage: '全球 90+ 國',
    price: 'NT$450–650',
    priceNote: '暢日卡PLUS',
    line: '漫遊',
    lineNote: '多國電信合作',
    hotspot: true,
    support: true,
    supportNote: 'LINE 24hr',
    forWho: '重度上網、商務人士',
    featured: false,
    tags: 'japan korea sea europe',
  },
  {
    name: 'Klook',
    badges: [{ label: '平台型', cls: 'badge-platform' }],
    coverage: '日、韓、東南亞、澳洲等',
    price: 'NT$350–550',
    priceNote: '吃到飽不降速',
    line: '漫遊',
    lineNote: '',
    hotspot: true,
    hotspotNote: '可分享',
    support: false,
    supportNote: '英文為主',
    forWho: '已用 Klook 訂行程者',
    featured: false,
    tags: 'japan korea sea',
  },
  {
    name: 'KKday',
    badges: [{ label: '平台型', cls: 'badge-platform' }],
    coverage: '日、韓、東南亞等',
    price: 'NT$295–623',
    priceNote: '含/不含門號',
    line: '漫遊',
    lineNote: '',
    hotspot: true,
    support: false,
    supportNote: '英文為主',
    forWho: '需要當地門號接簡訊者',
    featured: false,
    tags: 'japan korea',
  },
  {
    name: 'WaySim 威訊',
    badges: [{ label: 'CP值高', cls: 'badge-cp' }],
    coverage: '日本、韓國等',
    price: 'NT$289–549',
    priceNote: 'SK/Softbank 原生',
    line: '原生線路',
    lineNote: '5G 支援',
    hotspot: true,
    support: true,
    supportNote: 'LINE 客服',
    forWho: '日韓常客、預算有限者',
    featured: false,
    tags: 'japan korea',
  },
  {
    name: 'Airalo',
    badges: [{ label: '國際品牌', cls: 'badge-intl' }],
    coverage: '全球 190+ 國',
    price: 'NT$280–500',
    priceNote: '依方案不同',
    line: '漫遊',
    lineNote: '',
    hotspot: false,
    hotspotNote: '部分方案不支援',
    support: false,
    supportNote: '英文介面',
    forWho: '多國旅行、英文使用者',
    featured: false,
    tags: 'europe',
  },
