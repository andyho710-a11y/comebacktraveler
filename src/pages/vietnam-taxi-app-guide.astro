const title = "越南叫車 App 怎麼選?Grab、Be、Xanh SM 在地比較｜住越南十年的在地建議";
const description = "住越南十年的在地建議：Grab、Be、Xanh SM 三大叫車 App 怎麼選？以在地實際搭乘經驗比較價格、車況、對外國人友善度，加上機場叫車避雷指南。一次告訴你手機要裝哪幾個 App、哪些雷千萬別踩。";
const canonical = "https://comebacktraveler.com/vietnam-taxi-app-guide";
const cover = "https://comebacktraveler.com/vietnam-taxi-app.jpg";
