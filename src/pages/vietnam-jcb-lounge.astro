---
import SocialLinks from '../components/SocialLinks.astro';

const title = "越南新山一機場免費貴賓室攻略 2026：JCB 白金卡進 Rose Business Lounge 全紀錄｜重來的旅人";
const description = "搭廉航飛越南，也能用 JCB 白金卡免費進新山一機場的 Rose Business Lounge。住越南十年的過來人，把資格、位置、流程、踩雷重點整理清楚。";
const canonical = "https://comebacktraveler.com/vietnam-jcb-lounge";
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:image" content="https://comebacktraveler.com/vietnam-jcb-lounge-bar.jpg" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "url": canonical,
    "author": { "@type": "Person", "name": "重來的旅人" },
    "publisher": { "@type": "Organization", "name": "重來的旅人", "url": "https://comebacktraveler.com" },
    "dateModified": "2026-05-04",
    "image": "https://comebacktraveler.com/vietnam-jcb-lounge-bar.jpg"
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "JCB 金卡可以進新山一機場貴賓室嗎？",
        "acceptedAnswer": { "@type": "Answer", "text": "不行，越南新山一機場的 LoungeKey 服務僅限白金卡以上等級。金卡的免費貴賓室服務目前主要適用日本、夏威夷指定貴賓室。" }
      },
      {
        "@type": "Question",
        "name": "我不是台灣發行的 JCB 卡，可以用嗎？",
        "acceptedAnswer": { "@type": "Answer", "text": "各國 JCB 卡的規則不同，建議直接查詢你的卡片發行機構確認適用條件。" }
      },
      {
        "@type": "Question",
        "name": "附卡也可以免費進嗎？",
        "acceptedAnswer": { "@type": "Answer", "text": "部分卡別的附卡也可使用，但次數計算方式依各家銀行規定，出發前確認一下比較保險。" }
      },
      {
        "@type": "Question",
        "name": "在越南哪些機場可以用 JCB 貴賓室？",
        "acceptedAnswer": { "@type": "Answer", "text": "目前胡志明市新山一機場（SGN）與河內內排機場（HAN）都有配合，河內是 Song Hong Business Lounge。" }
      }
    ]
  })} />
  <style>
    :root {
      --ink: #1a1208;
      --ink-light: #4a3f2f;
      --paper: #faf8f3;
      --paper-warm: #f2ede0;
      --accent: #c0392b;
      --gold: #b8860b;
      --border: #d4c9b0;
      --serif: 'Noto Serif TC', serif;
      --sans: 'Noto Sans TC', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--paper); color: var(--ink); font-family: var(--sans); line-height: 1.8; font-size: 17px; }

    .site-header { border-bottom: 2px solid var(--ink); padding: 18px 0; text-align: center; background: var(--paper); position: sticky; top: 0; z-index: 100; }
    .site-name { font-family: var(--serif); font-weight: 900; font-size: 20px; letter-spacing: 0.12em; color: var(--ink); text-decoration: none; }
    .site-name span { color: var(--accent); }

    .hero { max-width: 740px; margin: 60px auto 0; padding: 0 24px; }
    .category-tag { font-size: 12px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); border-left: 3px solid var(--accent); padding-left: 10px; margin-bottom: 20px; }
    h1 { font-family: var(--serif); font-weight: 900; font-size: clamp(26px, 5vw, 42px); line-height: 1.35; margin-bottom: 20px; }
    .subtitle { font-size: 17px; color: var(--ink-light); margin-bottom: 32px; line-height: 1.7; }
    .meta { display: flex; align-items: center; gap: 20px; padding: 16px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-bottom: 48px; font-size: 13px; color: var(--ink-light); }
    .author-dot { width: 40px; height: 40px; border-radius: 50%; background: var(--ink); color: var(--paper); font-family: var(--serif); font-weight: 900; font-size: 15px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .meta-author { font-weight: 500; font-size: 14px; color: var(--ink); }

    .article { max-width: 740px; margin: 0 auto; padding: 0 24px 80px; }
    p { margin-bottom: 1.4em; }
    h2 { font-family: var(--serif); font-weight: 900; font-size: 26px; margin: 52px 0 16px; position: relative; padding-left: 16px; }
    h2::before { content: ''; position: absolute; left: 0; top: 4px; width: 4px; height: 80%; background: var(--accent); border-radius: 2px; }
    h3 { font-family: var(--serif); font-weight: 700; font-size: 19px; margin: 28px 0 10px; }

    .story-box { background: var(--paper-warm); border-left: 4px solid var(--accent); padding: 24px 28px; margin: 40px 0; border-radius: 0 6px 6px 0; font-family: var(--serif); font-size: 16px; color: var(--ink-light); line-height: 1.9; }
    .story-box strong { color: var(--ink); font-weight: 600; }

    .article-photo { width: 100%; height: auto; border-radius: 6px; margin: 32px 0 8px; display: block; }
    .photo-caption { font-size: 13px; color: var(--ink-light); text-align: center; margin-bottom: 32px; font-style: italic; }

    .info-card { border: 2px solid var(--border); border-radius: 8px; padding: 24px 28px; margin: 28px 0; background: #fff; }
    .info-card.featured { border-color: var(--accent); background: #fef9f5; }
    .info-card-label { font-size: 11px; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 8px; }
    .info-card h3 { margin-top: 0; }

    .qual-list { list-style: none; padding: 0; margin: 16px 0; }
    .qual-list li { padding: 12px 0; border-bottom: 1px dashed var(--border); display: flex; justify-content: space-between; align-items: center; gap: 16px; font-size: 15.5px; }
    .qual-list li:last-child { border-bottom: none; }
    .qual-list .qual-name { font-weight: 600; color: var(--ink); }
    .qual-list .qual-times { font-size: 14px; color: var(--accent); font-weight: 600; white-space: nowrap; }

    ol.steps { margin: 16px 0 16px 22px; }
    ol.steps li { margin-bottom: 8px; padding-left: 4px; }

    ul.bullets { margin: 12px 0 16px 22px; }
    ul.bullets li { margin-bottom: 8px; padding-left: 4px; }

    .tip-box { border: 1.5px solid var(--border); border-radius: 6px; padding: 20px 24px; margin: 32px 0; background: var(--paper); }
    .tip-title { font-weight: 500; font-size: 12px; letter-spacing: 0.12em; color: var(--gold); text-transform: uppercase; margin-bottom: 8px; }

    .warning-box { border-left: 4px solid var(--accent); background: #fef4f2; padding: 16px 20px; margin: 24px 0; border-radius: 0 6px 6px 0; font-size: 15px; color: var(--ink); }
    .warning-box strong { color: var(--accent); }

    .faq-item { border-top: 1px solid var(--border); padding: 20px 0; }
    .faq-item:last-child { border-bottom: 1px solid var(--border); }
    .faq-q { font-family: var(--serif); font-weight: 700; font-size: 17px; color: var(--ink); margin-bottom: 8px; }
    .faq-a { font-size: 15px; color: var(--ink-light); line-height: 1.75; }

    .closing { margin-top: 52px; padding-top: 32px; border-top: 1px solid var(--border); font-family: var(--serif); font-size: 16px; color: var(--ink-light); line-height: 1.9; }
    .closing em { color: var(--ink); font-style: normal; font-weight: 600; }

    .social-block { background: var(--paper-warm); border-radius: 8px; padding: 24px 28px; margin: 32px 0; }
    .social-block p { margin-bottom: 6px; font-size: 15px; color: var(--ink); }
    .social-block strong { color: var(--accent); }

    .quote { border-left: 3px solid var(--gold); padding: 8px 0 8px 18px; margin: 32px 0 8px; font-family: var(--serif); font-style: italic; color: var(--ink-light); font-size: 16px; line-height: 1.8; }

    .internal-links { margin: 40px 0 0; display: flex; gap: 20px; flex-wrap: wrap; }
    .internal-links a { color: var(--accent); text-decoration: none; font-size: 15px; font-weight: 500; }
    .internal-links a:hover { text-decoration: underline; }

    footer { border-top: 2px solid var(--ink); padding: 40px 24px; text-align: center; font-size: 13px; color: var(--ink-light); }
    .footer-nav { display: flex; justify-content: center; flex-wrap: wrap; gap: 6px 20px; margin-top: 14px; }
    .footer-nav a { color: var(--accent); text-decoration: none; font-size: 13px; }

    @media (max-width: 600px) {
      .hero, .article { padding: 0 16px; }
      .info-card { padding: 18px 20px; }
      .qual-list li { flex-direction: column; align-items: flex-start; gap: 4px; }
    }
  </style>
</head>
<body>

<header class="site-header">
  <a href="/" class="site-name">重來的<span>旅人</span></a>
</header>

<div class="hero">
  <div class="category-tag">越南旅遊 · 機場貴賓室攻略 2026</div>
  <h1>越南新山一機場免費貴賓室攻略<br>JCB 白金卡進 Rose Business Lounge 全紀錄</h1>
  <p class="subtitle">
    搭廉航飛越南，卻可以在機場享受和商務艙旅客一樣的待遇。<br>
    住越南十年的過來人，幫你把流程、位置、踩雷重點整理清楚。
  </p>
  <div class="meta">
    <div class="author-dot">旅</div>
    <div>
      <div class="meta-author">重來的旅人</div>
      <div>2026 年 5 月更新 · 越南生活 10 年 · 親身使用紀錄</div>
    </div>
  </div>
</div>

<article class="article">

  <img
    src="/vietnam-jcb-lounge-bar.jpg"
    alt="越南胡志明市新山一機場 Rose Business Lounge 吧台與用餐區"
    class="article-photo"
  />
  <p class="photo-caption">Rose Business Lounge 的吧台與落地窗用餐區，可以看到停機坪。</p>

  <div class="story-box">
    <strong>搭廉航飛越南，卻可以在機場享受和商務艙旅客一樣的待遇——這不是誇張。</strong><br><br>
    我在越南住了十年，最近才認真把 JCB 白金卡這個貴賓室權益用起來，<br>
    結果一試就回不去了。<br><br>
    這篇文章把流程、位置、裡面有什麼、注意事項全部整理清楚，<br>
    讓你出發前五分鐘看完直接走人。
  </div>

  <h2>JCB 白金卡進貴賓室：資格一次說清楚</h2>

  <p>持有以下任一張卡，就有資格免費進入越南新山一機場的 Rose Business Lounge：</p>

  <div class="info-card featured">
    <div class="info-card-label">適用卡別 · 免費次數</div>
    <ul class="qual-list">
      <li>
        <span class="qual-name">JCB 白金卡（Platinum）</span>
        <span class="qual-times">每卡每年 2 次</span>
      </li>
      <li>
        <span class="qual-name">JCB 晶緻卡（Precious）</span>
        <span class="qual-times">每卡每年 2 次</span>
      </li>
      <li>
        <span class="qual-name">JCB 極緻卡（Eternity）</span>
        <span class="qual-times">每卡每年 8 次</span>
      </li>
    </ul>
    <p style="margin:0;font-size:14.5px;color:var(--ink-light);">
      <strong style="color:var(--ink);">重要：</strong>
      完全沒有消費條件，不需要在出發前幾天刷卡、不需要刷達某金額。帶著卡和登機證走進去就好。
    </p>
  </div>

  <div class="tip-box">
    <div class="tip-title">使用提醒</div>
    <p style="margin:0;font-size:14px;">
      本服務透過 LoungeKey™ 系統運作，建議出發前先下載 LoungeKey APP 確認剩餘次數。
    </p>
  </div>

  <h2>Rose Business Lounge 在哪裡？怎麼走？</h2>

  <div class="info-card">
    <div class="info-card-label">📍 正確位置（2025 年更新）</div>
    <ul class="bullets">
      <li><strong>航廈：</strong>第二航廈（Terminal 2）</li>
      <li><strong>位置：</strong>安檢過後的離境大廳</li>
      <li><strong>登機門：</strong>Gate 8~9 附近</li>
    </ul>
  </div>

  <div class="warning-box">
    <strong>⚠️ 特別注意：</strong>原先配合的 Apricot Business Lounge 已於 2024 年 2 月終止與 JCB 合作，現在請認明 <strong>Rose Business Lounge</strong>，不要走錯了白跑一趟。
  </div>

  <h3>進場步驟</h3>
  <ol class="steps">
    <li>出示你的 JCB 卡</li>
    <li>出示當日登機證</li>
    <li>告知使用「LoungeKey™」服務</li>
    <li>服務人員掃描 → 進場</li>
  </ol>

  <h2>Rose Business Lounge 裡面有什麼？實際體驗報告</h2>

  <img
    src="/vietnam-jcb-lounge-buffet.jpg"
    alt="Rose Business Lounge 自助餐檯與吧檯座位區"
    class="article-photo"
  />
  <p class="photo-caption">自助餐檯一隅。越南河粉、法國麵包、輕食、冷盤一應俱全。</p>

  <p>在越南十年，我對越南的吃從不馬虎——貴賓室這點沒讓我失望。</p>

  <h3>餐飲</h3>
  <ul class="bullets">
    <li>越南河粉（Phở）現點現做，不是泡的那種</li>
    <li>越式法國麵包、炒飯、輕食</li>
    <li>啤酒、紅酒、各式軟飲免費暢飲</li>
    <li>在台灣機場貴賓室吃不到這個水準，說真的</li>
  </ul>

  <img
    src="/vietnam-jcb-lounge-seating.jpg"
    alt="Rose Business Lounge 沙發座位區與木製裝置藝術"
    class="article-photo"
  />
  <p class="photo-caption">座位區寬敞舒適，沙發區可以小睡，商務桌可以工作。</p>

  <h3>設施</h3>
  <ul class="bullets">
    <li>每個座位附近都有插座 + USB 充電口</li>
    <li>WiFi 穩定，我測過超過 30Mbps</li>
    <li>淋浴間（紅眼班機的救星）</li>
    <li>座位寬敞，有沙發區和商務桌</li>
  </ul>

  <p style="margin-top:24px;"><strong>整體評分：</strong>★★★★☆（越南機場貴賓室的水準一向不差）</p>

  <p>自費進場大約 945,000 越南盾（約 NT$1,200）——如果是免費的，CP 值就直接滿分。</p>

  <h2>使用 JCB 貴賓室的注意事項（踩雷避免清單）</h2>

  <ol class="steps">
    <li><strong>僅限本人：</strong>不能帶朋友一起進，同行者需另付費</li>
    <li><strong>走對貴賓室：</strong>一定要找 Rose Business Lounge，不是 Apricot</li>
    <li><strong>先確認 LoungeKey 次數：</strong>在 APP 裡查，別到了才發現用完</li>
    <li><strong>帶申請帳戶那張卡：</strong>官網建議出示，雖然有時候服務人員不要求</li>
    <li><strong>免費次數超過後：</strong>可以付費繼續使用，依各貴賓室定價</li>
  </ol>

  <h2>常見問題 FAQ</h2>

  <div class="faq-item">
    <div class="faq-q">Q：JCB 金卡可以進嗎？</div>
    <div class="faq-a">不行，越南新山一機場的 LoungeKey 服務僅限白金卡以上等級。金卡的免費貴賓室服務目前主要適用日本、夏威夷指定貴賓室。</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">Q：我不是台灣發行的 JCB 卡，可以用嗎？</div>
    <div class="faq-a">各國 JCB 卡的規則不同，建議直接查詢你的卡片發行機構確認適用條件。</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">Q：附卡也可以免費進嗎？</div>
    <div class="faq-a">部分卡別的附卡也可使用，但次數計算方式依各家銀行規定，出發前確認一下比較保險。</div>
  </div>
  <div class="faq-item">
    <div class="faq-q">Q：在越南哪些機場可以用？</div>
    <div class="faq-a">目前胡志明市新山一機場（SGN）與河內內排機場（HAN）都有配合，河內是 Song Hong Business Lounge。</div>
  </div>

  <h2>結語：去越南，別忘了帶這張卡</h2>

  <p>
    搭廉航省了機票錢，出發前三小時在貴賓室喝河粉喝啤酒——
    這才是我說的「出國省錢但不委屈」的生活方式。
  </p>

  <p>
    這篇沒有任何業配，純粹是我在越南住了十年後回頭整理的真實資訊。
    如果有幫到你，歡迎分享給要去越南的朋友，
    或是追蹤我的 IG 和 FB，我每週會分享一個出國省錢的實用技巧。
  </p>

  <SocialLinks
    heading="追蹤我｜Follow Me"
    subheading="有任何越南旅遊問題，歡迎直接留言或私訊我，我都會回。"
  />

  <div class="quote">
    走過彎路的人，才知道哪條路真的值得走。<br>
    — Comeback Traveler | comebacktraveler.com
  </div>

  <div class="closing">
    <em>祝你越南行順利，貴賓室位子也都剛好還有。</em>
  </div>

  <div class="internal-links">
    <a href="/vietnam-guide">→ 越南旅遊省時攻略</a>
    <a href="/esim">→ eSIM 品牌完整比較</a>
    <a href="/esim/install">→ eSIM 安裝圖解教學</a>
    <a href="/story">→ 我在越南的十年故事</a>
    <a href="/#klook-offers">→ Klook 優惠碼整理</a>
  </div>

</article>

<footer>
  <strong>重來的旅人</strong> · 把踩過的坑，變成你的攻略<br>
  <div class="footer-nav">
    <a href="/">← 回首頁</a>
    <a href="/vietnam-guide">越南快速通關</a>
    <a href="/esim">eSIM 比較</a>
    <a href="/japan-guide">日本攻略</a>
    <a href="/korea-guide">韓國攻略</a>
    <a href="/thsr-guide">高鐵省錢</a>
    <a href="/story">作者故事</a>
  </div>
</footer>

</body>
</html>
