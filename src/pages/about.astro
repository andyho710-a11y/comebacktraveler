---
import SocialLinks from '../components/SocialLinks.astro';
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const title = "關於重來的旅人｜這個網站與站長是誰";
const description = "重來的旅人（comebacktraveler.com）是誰、為什麼寫這個部落格、內容怎麼產出、聯盟連結如何揭露——一個在越南住了十年的台灣人，把踩過的坑整理成你能用的攻略。";
const canonical = "https://comebacktraveler.com/about";
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="profile" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="zh_TW" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;900&family=Noto+Sans+TC:wght@400;500&display=swap" rel="stylesheet">
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": title,
    "description": description,
    "url": canonical,
    "inLanguage": "zh-TW",
    "mainEntity": {
      "@type": "Person",
      "name": "重來的旅人",
      "alternateName": "何先生",
      "description": "在越南生活十年的台灣人，曾任工廠副總，返台後重新出發，經營旅遊與出國上網主題部落格。",
      "url": "https://comebacktraveler.com/about",
      "email": "andyho710@gmail.com",
      "sameAs": [
        "https://www.instagram.com/comebacktraveler",
        "http://www.youtube.com/@AndyFeverDream"
      ]
    },
    "publisher": { "@type": "Organization", "name": "重來的旅人", "url": "https://comebacktraveler.com" }
  })} />
  <style>
    :root {
      --ink: #1a1208;
      --ink-light: #4a3f2f;
      --paper: #faf8f3;
      --paper-warm: #f2ede0;
      --accent: #c0392b;
      --gold: #b8860b;
      --border: #d4c9b0;
      --serif: 'Noto Serif TC', serif;
      --sans: 'Noto Sans TC', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--paper); color: var(--ink); font-family: var(--sans); line-height: 1.8; font-size: 17px; }

    .hero { max-width: 740px; margin: 56px auto 0; padding: 0 24px; }
    .category-tag { font-size: 12px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); border-left: 3px solid var(--accent); padding-left: 10px; margin-bottom: 20px; }
    h1 { font-family: var(--serif); font-weight: 900; font-size: clamp(28px, 5vw, 42px); line-height: 1.35; margin-bottom: 20px; }
    .subtitle { font-size: 17px; color: var(--ink-light); margin-bottom: 32px; line-height: 1.7; }
    .meta { display: flex; align-items: center; gap: 20px; padding: 16px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-bottom: 48px; font-size: 13px; color: var(--ink-light); }
    .author-dot { width: 44px; height: 44px; border-radius: 50%; background: var(--ink); color: var(--paper); font-family: var(--serif); font-weight: 900; font-size: 16px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .meta-author { font-weight: 500; font-size: 14px; color: var(--ink); }

    .article { max-width: 740px; margin: 0 auto; padding: 0 24px 80px; }
    p { margin-bottom: 1.4em; }
    h2 { font-family: var(--serif); font-weight: 900; font-size: 24px; margin: 48px 0 14px; position: relative; padding-left: 16px; }
    h2::before { content: ''; position: absolute; left: 0; top: 4px; width: 4px; height: 80%; background: var(--accent); border-radius: 2px; }
    strong { color: var(--ink); }
    a { color: var(--accent); }

    .fact-list { list-style: none; padding: 0; margin: 8px 0 1.4em; }
    .fact-list li { padding: 12px 0 12px 18px; border-left: 3px solid var(--border); margin-bottom: 10px; font-size: 15.5px; color: var(--ink-light); line-height: 1.75; }
    .fact-list li strong { color: var(--ink); }

    .cta-row { display: flex; gap: 14px; flex-wrap: wrap; margin: 20px 0 0; }
    .cta-btn { display: inline-block; background: var(--accent); color: #fff; font-family: var(--serif); font-weight: 600; font-size: 15px; padding: 12px 26px; border-radius: 4px; text-decoration: none; }
    .cta-btn.secondary { background: var(--ink); }

    footer { border-top: 2px solid var(--ink); padding: 40px 24px; text-align: center; font-size: 13px; color: var(--ink-light); }
    .footer-nav { display: flex; justify-content: center; flex-wrap: wrap; gap: 6px 20px; margin-top: 14px; }
    .footer-nav a { color: var(--accent); text-decoration: none; font-size: 13px; }

    @media (max-width: 600px) { .hero, .article { padding: 0 16px; } }
  </style>
  <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2666904599101446" crossorigin="anonymous"></script>
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-XW4LBK8PYF"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XW4LBK8PYF');
  </script>
</head>
<body>

<SiteNav current="about" />

<div class="hero">
  <div class="category-tag">關於這個網站</div>
  <h1>把前半生踩過的坑，<br>整理成你用得上的攻略</h1>
  <p class="subtitle">
    我是「重來的旅人」，一個在越南住了十年、又回台灣重新出發的中年男人。<br>
    這頁說明我是誰、這個網站怎麼運作，以及你為什麼可以相信這裡寫的東西。
  </p>
  <div class="meta">
    <div class="author-dot">旅</div>
    <div>
      <div class="meta-author">重來的旅人 · 何先生</div>
      <div>越南生活 10 年 · 自媒體行銷 · 旅遊與出國上網筆記</div>
    </div>
  </div>
</div>

<article class="article">

  <h2>我是誰</h2>
  <p>
    我是家裡文具工廠的第二代。年輕時很叛逆，後來被送去越南幫父親管廠，擔任副總一待就是整整十年。
    那十年我經歷過工廠的興衰、養蝦事業的失敗、也看著父親病倒。2018 年回台灣，工廠被拍賣，我去跑了 Uber，
    外婆和父親也相繼離世。那是我人生最低的一段，但也是這個網站的起點——
    完整的故事我寫在 <a href="/story">這篇</a>，這裡先講和你比較有關的部分。
  </p>
  <p>
    在越南生活那麼久，我變成了朋友圈裡的「越南通」：誰要去胡志明市玩、誰第一次帶小孩出國、
    誰被機場計程車坑了，都會來問我。問的人多了，我乾脆把答案寫下來——這就是「重來的旅人」。
  </p>

  <h2>這個網站寫什麼</h2>
  <ul class="fact-list">
    <li><strong>出國上網 eSIM</strong>：品牌比較、原生 vs 漫遊線路、安裝教學、問題排解，以及資安爭議的白話解析。</li>
    <li><strong>日本、韓國、越南旅遊攻略</strong>：行程規劃、景點時段、票券怎麼買划算，越南部分是我十年生活的第一手經驗。</li>
    <li><strong>旅遊省錢情報</strong>：高鐵購票、銀行刷卡折扣、信用卡海外回饋。</li>
  </ul>

  <h2>內容是怎麼產出的</h2>
  <p>
    旅遊與越南生活類的文章，幾乎都是我親身經歷——住過的飯店、吃過的店、被坑過的計程車、帶女兒去玩的水樂園，
    文章裡的照片大多是我自己拍的。eSIM 與 3C 類的內容，則是依各家<strong>官方規格、線路類型、客服管道</strong>整理比較，
    並結合我自己與身邊朋友的實際使用回饋。我不會為了佣金硬推一個我不會用的東西。
  </p>

  <h2>關於聯盟連結與廣告</h2>
  <p>
    這個網站的營運靠兩件事支撐：<strong>聯盟行銷分潤</strong>與 <strong>Google AdSense 廣告</strong>。
    部分連結（例如 Klook、KKday、eSIM 品牌）是聯盟連結，你透過它們購買時，我會獲得少量分潤，
    但<strong>完全不會影響你付的價格</strong>。廣告則由第三方系統投放。
    這些收入讓我能持續更新內容，但不會影響我的推薦立場——詳細揭露寫在 <a href="/privacy">隱私權政策</a>。
  </p>

  <h2>想聯絡我</h2>
  <p>
    不管是內容回饋、合作邀約，還是單純想聊聊，都歡迎找我。我也接網站架設與程式開發的案子。
  </p>
  <div class="cta-row">
    <a href="/contact" class="cta-btn">聯絡方式 →</a>
    <a href="/story" class="cta-btn secondary">看完整的故事 →</a>
  </div>

  <SocialLinks
    heading="追蹤我｜Follow Me"
    subheading="IG、FB、YouTube 上會分享更多旅遊踩坑筆記與省錢情報"
  />

</article>

<SiteFooter />

</body>
</html>
