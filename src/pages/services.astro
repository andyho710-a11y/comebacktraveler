---
const title = "服務項目｜重來的旅人 Comeback Traveler";
const description = "網站架設、網頁設計、自動交易程式開發、智慧家庭安裝施工——每一項都親力親為，不假手外包。";
const canonical = "https://comebacktraveler.com/services";
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="架設網站,網頁設計,自動交易程式,智慧家庭,台灣接案" />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="zh_TW" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;600;700&family=Noto+Sans+TC:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink: #1a1510;
      --ink-light: #4a3f35;
      --paper: #faf8f4;
      --cream: #f2ede4;
      --amber: #c17f3a;
      --amber-dark: #96601e;
      --amber-light: #e8c98a;
      --rust: #8b3a2a;
      --sage: #5a6b52;
      --border: #d4c9b8;
      --shadow: rgba(26,21,16,0.08);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: 'Noto Sans TC', sans-serif;
      font-weight: 300;
      line-height: 1.8;
      overflow-x: hidden;
    }

    /* ── NAV ── */
    .site-nav {
      padding: 16px 24px;
      border-bottom: 1px solid var(--border);
      background: var(--paper);
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 13px;
      color: var(--ink-light);
    }
    .site-nav a {
      color: var(--amber);
      text-decoration: none;
      font-family: 'Noto Serif TC', serif;
      font-weight: 600;
      font-size: 14px;
    }
    .site-nav a:hover { color: var(--amber-dark); }
    .nav-sep { color: var(--border); }

    /* ── HERO ── */
    .hero {
      background: var(--ink);
      color: var(--paper);
      padding: 80px 24px 64px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 40% at 20% 50%, rgba(193,127,58,0.18) 0%, transparent 70%),
        radial-gradient(ellipse 40% 60% at 80% 30%, rgba(90,107,82,0.15) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.25em;
      color: var(--amber-light);
      text-transform: uppercase;
      margin-bottom: 20px;
      opacity: 0;
      animation: fadeUp 0.6s ease 0.2s forwards;
    }
    .hero h1 {
      font-family: 'DM Serif Display', 'Noto Serif TC', serif;
      font-size: clamp(32px, 6vw, 60px);
      font-weight: 400;
      line-height: 1.2;
      margin-bottom: 24px;
      opacity: 0;
      animation: fadeUp 0.7s ease 0.4s forwards;
    }
    .hero h1 em { font-style: italic; color: var(--amber-light); }
    .hero-sub {
      max-width: 540px;
      margin: 0 auto 40px;
      font-size: 15px;
      color: rgba(250,248,244,0.7);
      line-height: 1.9;
      opacity: 0;
      animation: fadeUp 0.7s ease 0.6s forwards;
    }
    .hero-contact-strip {
      display: inline-flex;
      gap: 32px;
      flex-wrap: wrap;
      justify-content: center;
      font-size: 13px;
      color: rgba(250,248,244,0.6);
      opacity: 0;
      animation: fadeUp 0.7s ease 0.8s forwards;
    }
    .hero-contact-strip a {
      color: var(--amber-light);
      text-decoration: none;
      transition: opacity 0.2s;
    }
    .hero-contact-strip a:hover { opacity: 0.75; }

    /* ── SECTION ── */
    .section {
      max-width: 960px;
      margin: 0 auto;
      padding: 72px 24px;
    }
    .section-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 12px;
    }
    .section-title {
      font-family: 'Noto Serif TC', serif;
      font-size: clamp(22px, 3.5vw, 34px);
      font-weight: 700;
      line-height: 1.35;
      color: var(--ink);
      margin-bottom: 48px;
    }

    /* ── SERVICE CARDS ── */
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 2px;
      background: var(--border);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }
    .service-card {
      background: var(--paper);
      padding: 40px 32px;
      transition: background 0.25s;
    }
    .service-card:hover { background: var(--cream); }
    .service-num {
      font-family: 'DM Serif Display', serif;
      font-size: 44px;
      font-weight: 400;
      color: var(--border);
      line-height: 1;
      margin-bottom: 14px;
      transition: color 0.25s;
    }
    .service-card:hover .service-num { color: var(--amber-light); }
    .service-icon { font-size: 26px; margin-bottom: 10px; }
    .service-name {
      font-family: 'Noto Serif TC', serif;
      font-size: 19px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 10px;
    }
    .service-desc {
      font-size: 13.5px;
      color: var(--ink-light);
      line-height: 1.85;
      margin-bottom: 18px;
    }
    .service-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-bottom: 16px;
    }
    .tag {
      font-size: 11px;
      font-weight: 500;
      padding: 3px 10px;
      border-radius: 100px;
      border: 1px solid var(--border);
      color: var(--ink-light);
      background: var(--cream);
    }
    .service-cta {
      font-size: 12px;
      color: var(--amber);
      font-weight: 500;
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
    }
    .service-cta:hover { border-color: var(--amber); }

    /* ── DETAILS ACCORDION ── */
    .pricing-details {
      margin-top: 40px;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .pricing-details summary {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 28px;
      background: var(--cream);
      cursor: pointer;
      user-select: none;
      list-style: none;
      gap: 16px;
      transition: background 0.2s;
    }
    .pricing-details summary::-webkit-details-marker { display: none; }
    .pricing-details[open] summary { background: var(--ink); color: var(--paper); }
    .pricing-details summary:hover:not(.pricing-details[open] summary) { background: #e8e0d4; }
    .summary-left {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .summary-icon { font-size: 20px; }
    .summary-title {
      font-family: 'Noto Serif TC', serif;
      font-size: 16px;
      font-weight: 700;
    }
    .summary-sub {
      font-size: 12px;
      color: var(--ink-light);
      margin-top: 2px;
    }
    .pricing-details[open] .summary-sub { color: rgba(250,248,244,0.55); }
    .summary-arrow {
      font-size: 18px;
      color: var(--amber);
      transition: transform 0.3s;
      flex-shrink: 0;
    }
    .pricing-details[open] .summary-arrow { transform: rotate(180deg); color: var(--amber-light); }

    .details-body {
      padding: 40px 32px 48px;
      background: var(--paper);
    }

    /* ── PLANS ── */
    .plans-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 48px;
    }
    @media (max-width: 600px) { .plans-row { grid-template-columns: 1fr; } }
    .plan-card {
      background: var(--paper);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 32px 28px;
      position: relative;
      transition: box-shadow 0.25s;
    }
    .plan-card:hover { box-shadow: 0 8px 32px var(--shadow); }
    .plan-card.featured { border-color: var(--amber); background: var(--ink); color: var(--paper); }
    .plan-badge {
      position: absolute;
      top: -12px;
      left: 24px;
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      background: var(--amber);
      color: white;
      padding: 3px 12px;
      border-radius: 100px;
    }
    .plan-name { font-family: 'Noto Serif TC', serif; font-size: 17px; font-weight: 700; margin-bottom: 4px; }
    .plan-subtitle { font-size: 12px; color: var(--ink-light); margin-bottom: 20px; }
    .plan-card.featured .plan-subtitle { color: rgba(250,248,244,0.6); }
    .plan-price {
      font-family: 'DM Serif Display', serif;
      font-size: 36px;
      font-weight: 400;
      color: var(--amber);
      line-height: 1;
      margin-bottom: 4px;
    }
    .plan-price-note { font-size: 12px; color: var(--ink-light); margin-bottom: 20px; }
    .plan-card.featured .plan-price-note { color: rgba(250,248,244,0.55); }
    .plan-items {
      list-style: none;
      border-top: 1px solid var(--border);
      padding-top: 16px;
    }
    .plan-card.featured .plan-items { border-color: rgba(250,248,244,0.15); }
    .plan-items li {
      font-size: 13px;
      padding: 7px 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      gap: 8px;
      line-height: 1.5;
    }
    .plan-card.featured .plan-items li { border-color: rgba(250,248,244,0.1); }
    .plan-items li::before { content: '✓'; color: var(--amber); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .plan-items li:last-child { border-bottom: none; }

    /* ── DETAIL TABLE ── */
    .sub-label {
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 12px;
    }
    .detail-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13.5px;
      margin-bottom: 16px;
    }
    .detail-table thead tr { background: var(--ink); color: var(--paper); }
    .detail-table thead th { padding: 12px 14px; text-align: left; font-weight: 500; font-size: 11px; letter-spacing: 0.08em; }
    .detail-table tbody tr { border-bottom: 1px solid var(--border); transition: background 0.15s; }
    .detail-table tbody tr:hover { background: rgba(193,127,58,0.04); }
    .detail-table td { padding: 13px 14px; vertical-align: top; color: var(--ink-light); line-height: 1.6; }
    .detail-table td:first-child { color: var(--ink); font-weight: 500; }
    .detail-table td:last-child {
      text-align: right;
      font-family: 'DM Serif Display', serif;
      font-size: 15px;
      color: var(--amber-dark);
      white-space: nowrap;
    }
    .table-note {
      font-size: 12px;
      color: var(--ink-light);
      padding: 14px 16px;
      background: rgba(193,127,58,0.05);
      border-left: 3px solid var(--amber-light);
      border-radius: 0 6px 6px 0;
      margin-bottom: 40px;
      line-height: 1.7;
    }

    /* ── PROCESS ── */
    .process-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0;
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      margin-bottom: 40px;
    }
    .process-step {
      padding: 24px 20px;
      border-right: 1px solid var(--border);
      text-align: center;
      background: var(--paper);
      transition: background 0.2s;
    }
    .process-step:last-child { border-right: none; }
    .process-step:hover { background: var(--cream); }
    .step-num { font-family: 'DM Serif Display', serif; font-size: 32px; color: var(--amber-light); line-height: 1; margin-bottom: 6px; }
    .step-name { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 4px; }
    .step-note { font-size: 11px; color: var(--ink-light); line-height: 1.6; }

    /* ── PAYMENT TERMS ── */
    .terms-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 40px;
    }
    @media (max-width: 580px) { .terms-grid { grid-template-columns: 1fr; } }
    .term-card {
      padding: 24px 20px;
      border: 1px solid var(--border);
      border-radius: 8px;
      text-align: center;
      background: var(--cream);
    }
    .term-pct { font-family: 'DM Serif Display', serif; font-size: 40px; font-weight: 400; color: var(--amber); line-height: 1; margin-bottom: 4px; }
    .term-label { font-size: 13px; font-weight: 500; color: var(--ink); margin-bottom: 4px; }
    .term-note { font-size: 11.5px; color: var(--ink-light); line-height: 1.6; }

    /* ── NOTES ── */
    .notes-list { list-style: none; display: grid; gap: 10px; }
    .notes-list li {
      display: flex;
      gap: 12px;
      font-size: 13.5px;
      color: var(--ink-light);
      line-height: 1.7;
      padding: 14px 18px;
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    .notes-list li::before {
      content: '！';
      font-size: 12px;
      font-weight: 700;
      color: var(--amber);
      background: rgba(193,127,58,0.12);
      width: 22px;
      height: 22px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }

    /* ── DIVIDER ── */
    .divider { border: none; border-top: 1px solid var(--border); margin: 0; }

    /* ── CTA ── */
    .cta-block {
      background: var(--ink);
      color: var(--paper);
      padding: 72px 24px;
      text-align: center;
    }
    .cta-block h2 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(26px, 4vw, 42px);
      font-weight: 400;
      margin-bottom: 14px;
    }
    .cta-block h2 em { font-style: italic; color: var(--amber-light); }
    .cta-sub {
      font-size: 15px;
      color: rgba(250,248,244,0.65);
      max-width: 460px;
      margin: 0 auto 36px;
      line-height: 1.85;
    }
    .cta-contacts { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 13px 28px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: all 0.2s;
      cursor: pointer;
    }
    .btn-primary { background: var(--amber); color: white; border: 1px solid var(--amber); }
    .btn-primary:hover { background: var(--amber-dark); border-color: var(--amber-dark); }
    .btn-outline { background: transparent; color: var(--paper); border: 1px solid rgba(250,248,244,0.3); }
    .btn-outline:hover { border-color: var(--amber-light); color: var(--amber-light); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .fade-in { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .fade-in.visible { opacity: 1; transform: translateY(0); }

    @media (max-width: 720px) {
      .service-card { padding: 28px 22px; }
      .section { padding: 52px 20px; }
      .details-body { padding: 28px 20px 36px; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="site-nav">
    <a href="/">重來的旅人</a>
    <span class="nav-sep">/</span>
    <span>服務項目</span>
  </nav>

  <!-- HERO -->
  <header class="hero">
    <p class="hero-label">重來的旅人 · Comeback Traveler</p>
    <h1>走過彎路的人，<br><em>更知道怎麼幫你</em></h1>
    <p class="hero-sub">旅遊以外，我也提供網站架設、網頁設計、自動交易程式開發與智慧家庭安裝——每一項都親力親為，不假手外包。</p>
    <div class="hero-contact-strip">
      <span>📞 <a href="tel:0986410888">0986-410-888</a></span>
      <span>✉️ <a href="mailto:andyho710@gmail.com">andyho710@gmail.com</a></span>
      <span>🌐 <a href="https://comebacktraveler.com">comebacktraveler.com</a></span>
    </div>
  </header>

  <!-- SERVICES -->
  <section class="section fade-in">
    <p class="section-label">服務項目</p>
    <h2 class="section-title">我能幫你做什麼</h2>

    <div class="services-grid">
      <div class="service-card">
        <div class="service-num">01</div>
        <div class="service-icon">🌐</div>
        <h3 class="service-name">架設網站</h3>
        <p class="service-desc">從網域申請、主機選擇、到網站上線，一條龍包辦。Astro 靜態高效能站或 WordPress 動態管理站，依需求選擇。含 SSL、每日備份與教學。</p>
        <div class="service-tags">
          <span class="tag">Astro</span>
          <span class="tag">WordPress</span>
          <span class="tag">SSL</span>
          <span class="tag">代管託管</span>
        </div>
        <a href="mailto:andyho710@gmail.com" class="service-cta">免費諮詢 →</a>
      </div>

      <div class="service-card">
        <div class="service-num">02</div>
        <div class="service-icon">🎨</div>
        <h3 class="service-name">網頁設計</h3>
        <p class="service-desc">品牌形象頁、活動頁、企業官網設計。SEO 優化設計，讓你的網站不只好看，也讓 Google 找得到你。詳細方案與報價請展開下方說明。</p>
        <div class="service-tags">
          <span class="tag">UI 設計</span>
          <span class="tag">RWD</span>
          <span class="tag">SEO 優化</span>
          <span class="tag">品牌識別</span>
        </div>
        <a href="#web-pricing" class="service-cta" id="open-pricing-link">查看詳細報價 ↓</a>
      </div>

      <div class="service-card">
        <div class="service-num">03</div>
        <div class="service-icon">📈</div>
        <h3 class="service-name">自動交易程式開發</h3>
        <p class="service-desc">客製化量化交易策略程式開發，支援 TradingView Pine Script、MT4/MT5 Expert Advisor 或 Python Bot。依策略邏輯規格報價，免費先諮詢。</p>
        <div class="service-tags">
          <span class="tag">Pine Script</span>
          <span class="tag">MT4/MT5</span>
          <span class="tag">Python</span>
          <span class="tag">回測優化</span>
        </div>
        <a href="mailto:andyho710@gmail.com" class="service-cta">免費諮詢 →</a>
      </div>

      <div class="service-card">
        <div class="service-num">04</div>
        <div class="service-icon">🏠</div>
        <h3 class="service-name">智慧家庭安裝施工</h3>
        <p class="service-desc">智慧燈控、門鎖、攝影機、語音助理、全屋自動化情境設定。到府評估後提供施工報價，安裝完成提供使用教學與後續支援。</p>
        <div class="service-tags">
          <span class="tag">智慧燈控</span>
          <span class="tag">門禁系統</span>
          <span class="tag">監控攝影</span>
          <span class="tag">Home Automation</span>
        </div>
        <a href="tel:0986410888" class="service-cta">電話詢問 →</a>
      </div>
    </div>

    <!-- WEB DESIGN PRICING — collapsible -->
    <details class="pricing-details fade-in" id="web-pricing">
      <summary>
        <div class="summary-left">
          <span class="summary-icon">🎨</span>
          <div>
            <div class="summary-title">網頁設計・詳細報價說明</div>
            <div class="summary-sub">方案比較、項目明細、工期與付款條款</div>
          </div>
        </div>
        <span class="summary-arrow">▾</span>
      </summary>

      <div class="details-body">

        <!-- Plans -->
        <p class="sub-label" style="margin-bottom:16px">選擇方案</p>
        <div class="plans-row">
          <div class="plan-card">
            <h3 class="plan-name">方案 A｜高效形象組</h3>
            <p class="plan-subtitle">Astro 靜態網站 + 雲端託管</p>
            <div class="plan-price">NT$ 37,800</div>
            <p class="plan-price-note">首年含開發、主機、網域、基本維護</p>
            <ul class="plan-items">
