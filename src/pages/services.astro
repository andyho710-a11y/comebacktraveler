  <script is:inline>
    // Scroll-in animation
    const observer = new IntersectionObserver(
      entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
      { threshold: 0.08 }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));

    // "查看詳細報價" click → open details and scroll to it
    const pricingLink = document.getElementById('open-pricing-link');
    const pricingDetails = document.getElementById('web-pricing');
    if (pricingLink && pricingDetails) {
      pricingLink.addEventListener('click', e => {
        e.preventDefault();
        pricingDetails.open = true;
        setTimeout(() => pricingDetails.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
      });
    }
